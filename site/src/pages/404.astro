---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Página não encontrada | Masterboard"
  description="A página que você procura não existe. Volte para o início do Masterboard."
  noindex={true}
>
  <Header />

  <main id="main-content" class="pt-20 min-h-screen flex items-center">
    <div class="container text-center py-24">
      <p class="text-8xl font-800 text-mb-yellow/20 mb-4" aria-hidden="true">404</p>
      <h1 class="section-title mb-4">Página não encontrada</h1>
      <p class="text-white/50 text-lg mb-8 max-w-sm mx-auto">
        A página que você procura não existe ou foi movida.
      </p>
      <a href="/" class="btn-primary">Voltar para o início</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

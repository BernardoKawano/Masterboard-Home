---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Metrics from '../components/Metrics.astro';
import Speakers from '../components/Speakers.astro';
import Members from '../components/Members.astro';
import ValueProps from '../components/ValueProps.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import Events from '../components/Events.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTAFinal from '../components/CTAFinal.astro';
import faqsData from '../data/faqs.json';
import { dataSource } from '../lib/data-source';

// Busca em paralelo — cada chamada tem fallback individual
// para que falhas pontuais de API não derrubem a página inteira (500)
const [upcomingEvents, speakers, members, memberCount] = await Promise.all([
  dataSource.listEvents({ status: 'upcoming', sortAscending: true, limit: 5 })
    .catch((e) => { console.error('[index] listEvents:', e); return []; }),
  dataSource.listSpeakers()
    .catch((e) => { console.error('[index] listSpeakers:', e); return []; }),
  (dataSource.listMembers?.() ?? Promise.resolve([]))
    .catch((e) => { console.error('[index] listMembers:', e); return []; }),
  (dataSource.getMemberCount?.() ?? Promise.resolve(undefined))
    .catch((e) => { console.error('[index] getMemberCount:', e); return undefined; }),
]);

// Temporariamente oculto — altere para true para exibir a seção de depoimentos novamente
const SHOW_TESTIMONIALS = false;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqsData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout
  title="Masterboard | O Ecossistema Fechado para Líderes que Estão no Jogo"
  description="Masterboard é o ecossistema empresarial fechado onde fundadores, CEOs e executivos encontram os pares certos para as decisões que realmente importam. Acesso por curadoria."
  jsonLd={[faqSchema]}
>
  <Header />

  <main id="main-content">
    <Hero />
    <ValueProps />
    <LogoMarquee />
    <Metrics />
    <Ecosystem />
    <Speakers speakers={speakers} />
    <Members members={members ?? []} speakers={speakers} memberCount={memberCount} />
    <Events events={upcomingEvents} limit={5} showViewAll={true} />
    {SHOW_TESTIMONIALS && <Testimonials />}
    <FAQ />
    <CTAFinal />
  </main>

  <Footer />
</BaseLayout>

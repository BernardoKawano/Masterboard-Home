---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const roleOptions = [
  'Sócio ou Fundador',
  'Presidente ou CEO',
  'Vice-presidente ou C-Level',
  'Diretor',
  'Gerente',
  'Coordenador',
  'Supervisor',
  'Analista',
];

const revenueOptions = [
  'Ainda não faturamos',
  'Até R$250 mil ao ano',
  'De R$250 mil a R$500 mil ao ano',
  'De R$500 mil a R$1 milhão ao ano',
  'De R$1 milhão a R$5 milhões ao ano',
  'De R$5 a R$10 milhões ao ano',
  'De R$10 a R$50 milhões ao ano',
  'De R$50 a R$500 milhões ao ano',
  'Acima de R$500 milhões',
];

const employeeOptions = [
  'Acima de 1.000 colaboradores',
  'De 101 a 1.000 colaboradores',
  'De 51 a 100 colaboradores',
  'De 10 a 50 colaboradores',
  'Até 10 colaboradores',
];

const countryCodeOptions = [
  { value: '+55', label: 'Brasil', hint: '+55' },
  { value: '+1', label: 'EUA / Canadá', hint: '+1' },
  { value: '+351', label: 'Portugal', hint: '+351' },
  { value: '+54', label: 'Argentina', hint: '+54' },
  { value: '+56', label: 'Chile', hint: '+56' },
  { value: '+57', label: 'Colômbia', hint: '+57' },
  { value: '+52', label: 'México', hint: '+52' },
  { value: '+598', label: 'Uruguai', hint: '+598' },
  { value: '+595', label: 'Paraguai', hint: '+595' },
];
---

<BaseLayout
  title="Candidatura Masterboard | Acesso por curadoria"
  description="Conte seu momento, porte da empresa e objetivo para entendermos se a sala Masterboard faz sentido para você."
  canonicalURL={new URL('/candidatura/', Astro.url).href}
>
  <Header />

  <main class="application-page">
    <section class="application-hero">
      <div class="container">
        <div class="application-shell">
          <aside class="application-context" aria-label="Contexto da candidatura">
            <p class="eyebrow mb-4">Candidatura Masterboard</p>
            <h1>A sala certa começa pelo filtro certo.</h1>
            <p>
              Precisamos entender seu momento, sua empresa e o tipo de conversa que pode gerar valor
              real para você e para quem já está dentro.
            </p>
            <div class="application-proof">
              <span>Curadoria antes do acesso</span>
              <span>Experiências presenciais</span>
              <span>Pares com contexto real</span>
            </div>
          </aside>

          <section class="application-card" aria-labelledby="application-title">
            <div class="application-progress" aria-hidden="true">
              <div class="application-progress__bar" data-progress-bar></div>
            </div>

            <form
              id="application-form"
              method="POST"
              action="/api/candidatura"
              novalidate
              aria-label="Formulário de candidatura ao Masterboard"
            >
              <input type="hidden" name="intencao" value="membro" />
              <input type="hidden" name="source" value="candidatura-page" />
              <input type="hidden" name="telefone" data-phone-full />

              <div class="application-step" data-step="0">
                <p class="application-kicker">Começamos simples.</p>
                <h2 id="application-title">Olá, qual é o seu e-mail profissional?</h2>
                <p class="application-copy">
                  Ele identifica sua aplicação e evita que você precise repetir informações depois.
                </p>
                <label class="form-label" for="field-email">E-mail</label>
                <input
                  id="field-email"
                  name="email"
                  type="email"
                  class="form-input application-input"
                  placeholder="voce@empresa.com"
                  required
                  data-required-label="e-mail profissional"
                  autocomplete="email"
                />
              </div>

              <div class="application-step" data-step="1" hidden>
                <p class="application-kicker">Obrigado pelo interesse.</p>
                <h2>Para priorizar sua aplicação, conte quem é você.</h2>
                <div class="application-field-stack">
                  <div class="application-field">
                    <label class="form-label" for="field-nome">1. Qual o seu nome completo?</label>
                    <input id="field-nome" name="nome" type="text" class="form-input application-input" placeholder="Seu nome completo" required data-required-label="nome completo" autocomplete="name" />
                  </div>
                  <div class="application-field">
                    <label class="form-label" for="field-country-code">Região / código do país</label>
                    <div class="application-field-control">
                      <select
                        id="field-country-code"
                        name="codigo_pais"
                        class="form-input application-input phone-code"
                        aria-label="Código do país"
                        data-phone-code
                      >
                        {countryCodeOptions.map((option) => (
                          <option value={option.value} selected={option.value === '+55'}>
                            {option.hint} · {option.label}
                          </option>
                        ))}
                      </select>
                    </div>
                  </div>
                  <div class="application-field">
                    <label class="form-label" for="field-whatsapp">2. E o seu WhatsApp?</label>
                    <div class="application-field-control">
                      <input
                        id="field-whatsapp"
                        name="whatsapp"
                        type="tel"
                        class="form-input application-input"
                        placeholder="11 9 0000-0000"
                        required
                        data-required-label="WhatsApp"
                        data-phone-local
                        autocomplete="tel-national"
                      />
                    </div>
                  </div>
                  <div class="application-field">
                    <label class="form-label" for="field-empresa">3. Qual o nome da sua empresa?</label>
                    <input id="field-empresa" name="empresa" type="text" class="form-input application-input" placeholder="Ex: Masterboard" required data-required-label="nome da empresa" autocomplete="organization" />
                  </div>
                  <div class="application-field">
                    <label class="form-label" for="field-website">4. Site da empresa <span class="form-label-optional">(opcional)</span></label>
                    <input id="field-website" name="website" type="url" class="form-input application-input" placeholder="https://suaempresa.com.br" autocomplete="url" />
                  </div>
                </div>
              </div>

              <div class="application-step" data-step="2" hidden>
                <h2>4. Qual o seu cargo na empresa?</h2>
                <p class="application-copy">Isso ajuda a entender se você está na cadeira certa para a sala.</p>
                <div class="application-options">
                  {roleOptions.map((option, index) => (
                    <label class="application-option">
                      <input type="radio" name="cargo" value={option} required data-required-label="cargo" checked={index === 0} />
                      <span>{option}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="application-step" data-step="3" hidden>
                <h2>5. Qual o faturamento anual da sua empresa?</h2>
                <p class="application-copy">A resposta orienta a curadoria, não aparece publicamente.</p>
                <div class="application-options">
                  {revenueOptions.map((option) => (
                    <label class="application-option">
                      <input type="radio" name="faturamento" value={option} required data-required-label="faturamento anual" />
                      <span>{option}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="application-step" data-step="4" hidden>
                <h2>6. Quantos colaboradores sua empresa possui?</h2>
                <p class="application-copy">Tamanho de operação muda o tipo de troca que faz sentido.</p>
                <div class="application-options">
                  {employeeOptions.map((option) => (
                    <label class="application-option">
                      <input type="radio" name="colaboradores" value={option} required data-required-label="número de colaboradores" />
                      <span>{option}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="application-step" data-step="5" hidden>
                <h2>7. O que faria essa sala valer seu tempo agora?</h2>
                <p class="application-copy">Último contexto antes da curadoria.</p>
                <label class="form-label" for="field-momento">Momento da empresa</label>
                <select id="field-momento" name="momento" class="form-input application-input">
                  <option value="">Selecione se quiser</option>
                  <option value="crescimento">Crescimento acelerado</option>
                  <option value="expansao">Expansão para novos mercados</option>
                  <option value="reposicionamento">Reposicionamento estratégico</option>
                  <option value="capital">Busca de capital ou M&A</option>
                  <option value="network">Rede certa para próximos passos</option>
                </select>

                <label class="form-label mt-4" for="field-objetivo">Objetivo principal</label>
                <textarea
                  id="field-objetivo"
                  name="objetivo"
                  class="form-input application-input min-h-28"
                  placeholder="Ex: tomar decisões melhores com pares que vivem desafios parecidos."
                ></textarea>

                <label class="form-label mt-4" for="field-evento-interesse">Há algum evento de interesse específico? <span class="form-label-optional">(opcional)</span></label>
                <input
                  id="field-evento-interesse"
                  name="evento_interesse"
                  type="text"
                  class="form-input application-input"
                  placeholder="Ex: Master #102 — Governança"
                />

                <label class="application-consent">
                  <input id="field-lgpd" name="lgpd" type="checkbox" required data-required-label="aceite da Política de Privacidade" />
                  <span>
                    Concordo com a <a href="/politica-de-privacidade/" target="_blank">Política de Privacidade</a>
                    e autorizo o contato da equipe Masterboard.
                  </span>
                </label>
              </div>

              <div class="hidden" aria-hidden="true">
                <input name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
              </div>

              <div id="application-error" class="application-message application-message--error" hidden role="alert"></div>
              <div id="application-success" class="application-message application-message--success" hidden role="status">
                Candidatura recebida. Se houver fit, nossa equipe entra em contato.
              </div>

              <div class="application-actions">
                <button type="button" class="btn-primary" data-next>Continuar</button>
                <button type="submit" class="btn-primary" data-submit hidden>Enviar para curadoria</button>
              </div>
            </form>

            <section class="application-thanks" data-thanks hidden aria-live="polite">
              <p class="application-kicker">Candidatura recebida.</p>
              <h2>Obrigado. Agora é com a curadoria.</h2>
              <p>
                Sua aplicação entrou na fila de análise da Masterboard. Vamos olhar seu momento,
                porte de empresa e objetivo para entender se existe fit com a sala certa.
              </p>
              <p>
                Se fizer sentido para os dois lados, nossa equipe entra em contato pelo WhatsApp informado.
              </p>
              <a href="/" class="btn-secondary">Voltar ao site</a>
            </section>
          </section>
        </div>
      </div>
    </section>
  </main>

</BaseLayout>

<script>
  const form = document.getElementById('application-form') as HTMLFormElement | null;
  const steps = Array.from(document.querySelectorAll<HTMLElement>('[data-step]'));
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-next]');
  const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit]');
  const progressBar = document.querySelector<HTMLElement>('[data-progress-bar]');
  const errorEl = document.getElementById('application-error');
  const successEl = document.getElementById('application-success');
  const thanksEl = document.querySelector<HTMLElement>('[data-thanks]');
  const phoneCode = document.querySelector<HTMLSelectElement>('[data-phone-code]');
  const phoneLocal = document.querySelector<HTMLInputElement>('[data-phone-local]');
  const phoneFull = document.querySelector<HTMLInputElement>('[data-phone-full]');
  let currentStep = 0;

  const fieldLabel = (field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) =>
    field.dataset.requiredLabel || field.labels?.[0]?.textContent?.replace(/\s+/g, ' ').trim() || field.name || 'campo obrigatório';

  const showMessage = (message: string) => {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
    successEl?.setAttribute('hidden', '');
  };

  const updateStep = () => {
    steps.forEach((step, index) => {
      step.hidden = index !== currentStep;
    });
    if (nextBtn) nextBtn.hidden = currentStep === steps.length - 1;
    if (submitBtn) submitBtn.hidden = currentStep !== steps.length - 1;
    if (progressBar) progressBar.style.width = `${((currentStep + 1) / steps.length) * 100}%`;
    errorEl?.setAttribute('hidden', '');
  };

  const syncPhone = () => {
    if (!phoneFull) return;

    const code = phoneCode?.value.trim() || '+55';
    const local = phoneLocal?.value.trim() || '';
    phoneFull.value = local ? `${code} ${local}` : '';
  };

  const validateCurrentStep = () => {
    const current = steps[currentStep];
    const fields = Array.from(current.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('input, select, textarea'));
    const missing: string[] = [];
    const seenRadioGroups = new Set<string>();

    for (const field of fields) {
      if (!field.required) continue;

      if (field instanceof HTMLInputElement && field.type === 'radio') {
        if (seenRadioGroups.has(field.name)) continue;
        seenRadioGroups.add(field.name);
        if (!current.querySelector<HTMLInputElement>(`input[type="radio"][name="${field.name}"]:checked`)) {
          missing.push(fieldLabel(field));
        }
        continue;
      }

      if (field instanceof HTMLInputElement && field.type === 'checkbox') {
        if (!field.checked) missing.push(fieldLabel(field));
        continue;
      }

      if (!field.value.trim()) {
        missing.push(fieldLabel(field));
        continue;
      }

      if (!field.checkValidity()) {
        missing.push(field.type === 'email' ? 'e-mail válido' : fieldLabel(field));
      }
    }

    if (missing.length > 0) {
      showMessage(`Falta preencher: ${missing.join(', ')}.`);
      return false;
    }

    return true;
  };

  nextBtn?.addEventListener('click', () => {
    if (!validateCurrentStep()) return;
    currentStep = Math.min(currentStep + 1, steps.length - 1);
    updateStep();
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!validateCurrentStep() || !submitBtn) return;

    syncPhone();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando para curadoria...';

    try {
      const data = new FormData(form);
      if (data.get('_gotcha')) return;

      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) {
        throw new Error('Falha ao enviar candidatura');
      }

      form.hidden = true;
      progressBar?.parentElement?.setAttribute('hidden', '');
      thanksEl?.removeAttribute('hidden');
      errorEl?.setAttribute('hidden', '');
      thanksEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      showMessage('Não conseguimos enviar agora. Tente novamente em instantes.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar para curadoria';
    }
  });

  phoneCode?.addEventListener('change', syncPhone);
  phoneLocal?.addEventListener('input', syncPhone);
  updateStep();
</script>

<style>
  .application-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at 12% 10%, rgba(251,190,10,0.14), transparent 28rem),
      radial-gradient(circle at 88% 30%, rgba(255,255,255,0.08), transparent 26rem),
      var(--mb-black);
  }

  .application-hero {
    min-height: calc(100vh - 5rem);
    display: flex;
    align-items: center;
    padding: clamp(4.8rem, 8vh, 6.2rem) 0 clamp(1.8rem, 4vh, 3rem);
  }

  .application-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(24rem, 0.9fr);
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: center;
  }

  .application-context {
    position: sticky;
    top: 7rem;
  }

  .application-context h1 {
    color: var(--mb-white);
    font-size: clamp(2.4rem, 5.4vw, 5.1rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.035em;
    max-width: 13.5ch;
  }

  .application-context p {
    margin-top: 1rem;
    max-width: 35rem;
    color: rgba(255,255,255,0.64);
    font-size: clamp(1rem, 1.4vw, 1.16rem);
    line-height: 1.65;
    letter-spacing: 0.012em;
  }

  .application-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.35rem;
  }

  .application-proof span {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 0.45rem 0.68rem;
    color: rgba(255,255,255,0.62);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.025em;
  }

  .application-card {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 1.6rem;
    background: rgba(8,8,8,0.86);
    box-shadow: 0 30px 90px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.05);
    padding: clamp(1.25rem, 2.4vw, 1.85rem);
  }

  .application-progress {
    height: 0.28rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    margin-bottom: clamp(1.2rem, 2.2vw, 1.75rem);
  }

  .application-progress__bar {
    width: 16.66%;
    height: 100%;
    border-radius: inherit;
    background: var(--mb-yellow);
    transition: width 0.25s ease;
  }

  .application-step h2 {
    color: var(--mb-white);
    font-size: clamp(1.35rem, 2.35vw, 1.95rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.018em;
    margin-bottom: 0.8rem;
  }

  .application-kicker {
    color: var(--mb-yellow);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 0.72rem;
  }

  .application-copy {
    color: rgba(255,255,255,0.54);
    line-height: 1.55;
    letter-spacing: 0.012em;
    margin-bottom: 1rem;
  }

  .form-label-optional {
    color: rgba(255,255,255,0.34);
    font-weight: 400;
    font-size: 0.82em;
  }

  .application-input {
    min-height: 2.85rem;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: 0.012em;
  }

  textarea.application-input {
    min-height: 5.6rem;
  }

  .application-field-stack {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.82rem;
  }

  .application-field {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
  }

  .application-field-control {
    width: 100%;
  }

  .phone-code {
    padding-left: 0.85rem;
    padding-right: 0.85rem;
  }

  .application-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    margin-top: 0.2rem;
  }

  .application-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.95rem;
    padding: 0.62rem 0.75rem;
    color: rgba(255,255,255,0.74);
    background: rgba(255,255,255,0.035);
    cursor: pointer;
    line-height: 1.3;
    letter-spacing: 0.01em;
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .application-option:has(input:checked) {
    border-color: rgba(251,190,10,0.55);
    background: rgba(251,190,10,0.1);
    color: var(--mb-white);
  }

  .application-option input,
  .application-consent input {
    accent-color: var(--mb-yellow);
  }

  .application-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 0.95rem;
    color: rgba(255,255,255,0.54);
    font-size: 0.82rem;
    line-height: 1.45;
    letter-spacing: 0.01em;
  }

  .application-consent a {
    color: rgba(255,255,255,0.78);
    text-decoration: underline;
  }

  .application-message {
    margin-top: 0.85rem;
    margin-bottom: 0.25rem;
    border-radius: 0.9rem;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    line-height: 1.55;
    letter-spacing: 0.01em;
  }

  .application-message--error {
    border: 1px solid rgba(239,68,68,0.35);
    background: rgba(239,68,68,0.1);
    color: #fca5a5;
  }

  .application-message--success {
    border: 1px solid rgba(251,190,10,0.3);
    background: rgba(251,190,10,0.1);
    color: var(--mb-yellow);
  }

  .application-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: clamp(1.05rem, 2vw, 1.55rem);
  }

  .application-thanks {
    text-align: left;
  }

  .application-thanks h2 {
    color: var(--mb-white);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .application-thanks p {
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    letter-spacing: 0.012em;
    margin-bottom: 1.15rem;
  }

  .application-thanks .btn-secondary {
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .application-shell {
      grid-template-columns: 1fr;
    }

    .application-context {
      position: static;
      margin-bottom: 0.25rem;
    }

    .application-context h1 {
      max-width: 15ch;
    }
  }

  @media (max-height: 760px) and (min-width: 901px) {
    .application-hero {
      padding-top: 4.6rem;
      padding-bottom: 1.25rem;
    }

    .application-context h1 {
      font-size: clamp(2.25rem, 4.6vw, 4.35rem);
    }

    .application-context p {
      font-size: 0.98rem;
      line-height: 1.5;
    }

    .application-proof {
      margin-top: 1rem;
    }

    .application-card {
      padding: 1.2rem;
    }

    .application-step h2 {
      font-size: clamp(1.25rem, 2vw, 1.7rem);
    }

    .application-copy {
      margin-bottom: 0.85rem;
    }
  }

  @media (max-width: 520px) {
    .application-hero {
      padding-top: 5.5rem;
      padding-bottom: 4rem;
      align-items: flex-start;
    }

    .application-card {
      padding: 1.25rem;
      border-radius: 1.25rem;
    }

    .application-options {
      grid-template-columns: 1fr;
    }
  }
</style>

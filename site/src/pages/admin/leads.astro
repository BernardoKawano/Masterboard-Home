---
export const prerender = false;

import { createServerSupabaseClient } from '../../lib/supabase-client';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { canManageLeads, getAdminSession } from '../../lib/admin/auth';
import {
  formatLeadSourceLabel,
  getLeadBrandLabel,
  leadSourceFilterValues,
  parseLeadSource,
} from '../../lib/lead-source.mjs';
import { isDraftLead, parseLeadNotes } from '../../lib/candidatura-payload.mjs';
import {
  excludeDraftLeads,
  filterDraftLeads,
  filterNewLeads,
} from '../../lib/admin/lead-query.mjs';

type LeadRow = Record<string, unknown>;
type ViewMode = 'list' | 'board';
type EffectiveStatus = 'draft' | 'new' | 'contacted' | 'approved' | 'rejected';

const supabaseUrl = import.meta.env.SUPABASE_URL;
const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const session = await getAdminSession(Astro);
if (!session) return Astro.redirect(`/admin/login/?next=${encodeURIComponent('/admin/leads/')}`);

const isAuthorized = canManageLeads(session);
const selectedStatus = Astro.url.searchParams.get('status') ?? 'all';
const selectedBrand = Astro.url.searchParams.get('brand') ?? 'all';
const viewMode: ViewMode = Astro.url.searchParams.get('view') === 'board' ? 'board' : 'list';

const parseNotes = (value: unknown) => {
  if (typeof value !== 'string' || !value.trim()) return {};
  try {
    return JSON.parse(value) as Record<string, unknown>;
  } catch {
    return {};
  }
};

const text = (value: unknown, fallback = '-') => {
  if (typeof value === 'string' && value.trim()) return value;
  if (typeof value === 'number') return String(value);
  return fallback;
};

const formatDate = (value: unknown) => {
  if (typeof value !== 'string') return '-';
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: '2-digit',
    year: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    timeZone: 'America/Sao_Paulo',
  }).format(new Date(value));
};

const formatShortDate = (value: unknown) => {
  if (typeof value !== 'string') return '-';
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'short',
    timeZone: 'America/Sao_Paulo',
  }).format(new Date(value));
};

const getQualification = (lead: LeadRow) => {
  const notes = parseNotes(lead.notes);
  return {
    revenue: text(lead.annual_revenue ?? notes.faturamento),
    employees: text(lead.employee_count ?? notes.colaboradores),
    moment: text(lead.company_moment ?? notes.momento),
    objective: text(lead.objective ?? notes.objetivo),
    score: Number(lead.score ?? notes.score ?? 0) || 0,
    priority: text(lead.priority ?? notes.priority, 'normal'),
    whatsapp: text(lead.whatsapp ?? notes.whatsapp),
  };
};

const getEffectiveStatus = (lead: LeadRow): EffectiveStatus => {
  if (isDraftLead(lead)) return 'draft';
  const status = text(lead.status, 'new');
  if (status === 'contacted' || status === 'approved' || status === 'rejected') return status;
  return 'new';
};

const getInitials = (name: string, email: string) => {
  const clean = name.trim();
  if (clean && clean !== '(em preenchimento)' && clean !== '(sem nome)' && clean !== '-') {
    const parts = clean.split(/\s+/).filter(Boolean);
    if (parts.length >= 2) return `${parts[0][0]}${parts[parts.length - 1][0]}`.toUpperCase();
    return parts[0].slice(0, 2).toUpperCase();
  }
  return email.slice(0, 2).toUpperCase();
};

const priorityLabels: Record<string, string> = {
  high: 'Alta',
  normal: 'Normal',
  low: 'Baixa',
};

const statusLabels: Record<string, string> = {
  all: 'Todos',
  new: 'Novos',
  draft: 'Rascunhos',
  contacted: 'Contatados',
  approved: 'Aprovados',
  rejected: 'Rejeitados',
};

const brandLabels: Record<string, string> = {
  all: 'Todas as marcas',
  masterboard: 'Masterboard',
  scale: 'Scale',
};

const boardColumns: { id: EffectiveStatus; label: string; hint: string }[] = [
  { id: 'draft', label: 'Rascunhos', hint: 'Abandonou o formulário' },
  { id: 'new', label: 'Novos', hint: 'Aguardando contato' },
  { id: 'contacted', label: 'Contatados', hint: 'Em conversa' },
  { id: 'approved', label: 'Aprovados', hint: 'Entrou na curadoria' },
  { id: 'rejected', label: 'Rejeitados', hint: 'Não seguiu' },
];

const statusOptions = ['all', 'new', 'draft', 'contacted', 'approved', 'rejected'];
const brandOptions = ['all', 'masterboard', 'scale'] as const;

const buildLeadsHref = (params: { status?: string; brand?: string; view?: ViewMode }) => {
  const search = new URLSearchParams();
  const status = params.status ?? selectedStatus;
  const brand = params.brand ?? selectedBrand;
  const view = params.view ?? viewMode;
  if (status !== 'all') search.set('status', status);
  if (brand !== 'all') search.set('brand', brand);
  if (view === 'board') search.set('view', 'board');
  const query = search.toString();
  return query ? `/admin/leads/?${query}` : '/admin/leads/';
};

const applyBrandFilter = (
  query: ReturnType<ReturnType<typeof createServerSupabaseClient>['from']>,
  brand: string,
) => {
  const brandFilter = leadSourceFilterValues(
    brand === 'masterboard' || brand === 'scale' ? brand : 'all',
  );
  if (brand !== 'all' && brandFilter?.supabaseOr) {
    return query.or(brandFilter.supabaseOr);
  }
  return query;
};

let leads: LeadRow[] = [];
let errorMessage = '';
let globalCounts: Record<EffectiveStatus | 'total', number> = {
  total: 0,
  draft: 0,
  new: 0,
  contacted: 0,
  approved: 0,
  rejected: 0,
};

if (isAuthorized && supabaseUrl && serviceRoleKey) {
  const supabase = createServerSupabaseClient(supabaseUrl, serviceRoleKey);

  const countWithBrand = async (modifier: (q: ReturnType<typeof supabase.from>) => typeof q) => {
    let q = supabase.from('leads').select('id', { count: 'exact', head: true });
    q = applyBrandFilter(q, selectedBrand) as typeof q;
    return modifier(q);
  };

  const [
    totalRes,
    draftRes,
    newRes,
    contactedRes,
    approvedRes,
    rejectedRes,
    leadsRes,
  ] = await Promise.all([
    countWithBrand((q) => q),
    countWithBrand((q) => filterDraftLeads(q)),
    countWithBrand((q) => filterNewLeads(q)),
    countWithBrand((q) => q.eq('status', 'contacted')),
    countWithBrand((q) => q.eq('status', 'approved')),
    countWithBrand((q) => q.eq('status', 'rejected')),
    (async () => {
      let query = supabase
        .from('leads')
        .select('*')
        .order('submitted_at', { ascending: false })
        .limit(viewMode === 'board' ? 150 : 100);

      if (viewMode === 'list') {
        if (selectedStatus === 'draft') {
          query = filterDraftLeads(query);
        } else if (selectedStatus === 'all') {
          query = excludeDraftLeads(query);
        } else if (selectedStatus === 'new') {
          query = filterNewLeads(query);
        } else {
          query = query.eq('status', selectedStatus);
        }
      }

      query = applyBrandFilter(query, selectedBrand) as typeof query;
      return await query;
    })(),
  ]);

  globalCounts = {
    total: totalRes.count ?? 0,
    draft: draftRes.count ?? 0,
    new: newRes.count ?? 0,
    contacted: contactedRes.count ?? 0,
    approved: approvedRes.count ?? 0,
    rejected: rejectedRes.count ?? 0,
  };

  const { data, error } = await leadsRes;
  if (error) {
    errorMessage = error.message;
  } else {
    leads = (data ?? []) as LeadRow[];
  }
} else if (!supabaseUrl || !serviceRoleKey) {
  errorMessage = 'SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY precisam estar configurados.';
}

const leadsByColumn = boardColumns.reduce(
  (acc, col) => {
    acc[col.id] = leads.filter((lead) => getEffectiveStatus(lead) === col.id);
    return acc;
  },
  {} as Record<EffectiveStatus, LeadRow[]>,
);

const FORM_STEPS = 7;

const scoreColor = (score: number) => {
  if (score >= 70) return '#fbbf0a';
  if (score >= 30) return '#93c5fd';
  return '#94a3b8';
};
---

<AdminLayout
  title="Leads"
  description="Painel visual de candidaturas Masterboard."
  active="leads"
  session={session}
>
  {!isAuthorized ? (
    <section class="lead-empty admin-card">
      <h2>Acesso restrito</h2>
      <p>Somente usuários com papel <code>admin</code> podem visualizar leads.</p>
    </section>
  ) : errorMessage ? (
    <section class="lead-empty admin-card">
      <h2>Não foi possível carregar os leads</h2>
      <p>{errorMessage}</p>
    </section>
  ) : (
  <>
    <header class="lead-header">
      <div>
        <p class="lead-eyebrow">Operação Masterboard</p>
        <h1>Leads do site</h1>
        <p>Visualize candidaturas, rascunhos e prioridade de contato em tempo real.</p>
      </div>
      <div class="lead-header__actions">
        <nav class="lead-view-toggle" aria-label="Modo de visualização">
          <a href={buildLeadsHref({ view: 'list' })} aria-current={viewMode === 'list' ? 'page' : undefined}>
            Lista
          </a>
          <a href={buildLeadsHref({ view: 'board' })} aria-current={viewMode === 'board' ? 'page' : undefined}>
            Quadro
          </a>
        </nav>
        <a href="/aplicacao/" class="lead-link" target="_blank" rel="noopener noreferrer">Ver formulário</a>
      </div>
    </header>

    <section class="lead-metrics" aria-label="Resumo de leads">
      <a href={buildLeadsHref({ status: 'all', view: viewMode })} class="lead-metric" data-active={selectedStatus === 'all' && viewMode === 'list' ? 'true' : undefined}>
        <span class="lead-metric__value">{globalCounts.total}</span>
        <span class="lead-metric__label">Total</span>
      </a>
      {boardColumns.map((col) => (
        <a
          href={buildLeadsHref({ status: col.id, view: 'list' })}
          class="lead-metric"
          data-status={col.id}
          data-active={selectedStatus === col.id && viewMode === 'list' ? 'true' : undefined}
        >
          <span class="lead-metric__value">{globalCounts[col.id]}</span>
          <span class="lead-metric__label">{col.label}</span>
        </a>
      ))}
    </section>

    <nav class="lead-filters" aria-label="Filtrar por marca">
      {brandOptions.map((brand) => (
        <a href={buildLeadsHref({ brand, view: viewMode })} aria-current={selectedBrand === brand ? 'page' : undefined}>
          {brandLabels[brand]}
        </a>
      ))}
    </nav>

    {viewMode === 'list' && (
      <nav class="lead-filters" aria-label="Filtrar por status">
        {statusOptions.map((status) => (
          <a href={buildLeadsHref({ status, view: 'list' })} aria-current={selectedStatus === status ? 'page' : undefined}>
            {statusLabels[status]}
          </a>
        ))}
      </nav>
    )}

    {viewMode === 'board' ? (
      <section class="lead-board" aria-label="Quadro de leads">
        {boardColumns.map((col) => {
          const columnLeads = leadsByColumn[col.id];
          return (
            <div class="lead-column" data-status={col.id}>
              <header class="lead-column__header">
                <div>
                  <h2>{col.label}</h2>
                  <p>{col.hint}</p>
                </div>
                <span class="lead-column__count">{globalCounts[col.id]}</span>
              </header>
              <div class="lead-column__cards">
                {columnLeads.length === 0 ? (
                  <p class="lead-column__empty">Nenhum lead aqui</p>
                ) : (
                  columnLeads.map((lead) => {
                    const q = getQualification(lead);
                    const displayName = text(lead.name, col.id === 'draft' ? '(sem nome)' : '-');
                    const initials = getInitials(displayName, text(lead.email));
                    const notes = parseLeadNotes(lead.notes);
                    const formStep = Number(notes.form_step ?? 0);
                    const whatsapp = text(lead.phone);
                    const whatsappUrl = whatsapp !== '-' ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : '';
                    const club = text(lead.evento_interesse);
                    const shortClub = club !== '-' ? club.replace('Masterboard Club — ', '') : '-';

                    return (
                      <article class="lead-mini-card" data-priority={q.priority} data-lead-id={String(lead.id)}>
                        <div class="lead-mini-card__top">
                          <div class="lead-avatar" aria-hidden="true">{initials}</div>
                          <div class="lead-mini-card__identity">
                            <p class="lead-mini-card__name">{displayName}</p>
                            <p class="lead-mini-card__company">{text(lead.company, col.id === 'draft' ? '—' : '-')}</p>
                          </div>
                          <div class="lead-score" data-score={q.score} title={`Score ${q.score}`}>
                            <svg viewBox="0 0 36 36" aria-hidden="true">
                              <circle class="lead-score__track" cx="18" cy="18" r="15.5" />
                              <circle
                                class="lead-score__fill"
                                cx="18"
                                cy="18"
                                r="15.5"
                                style={`stroke-dasharray: ${q.score} 100; stroke: ${scoreColor(q.score)}`}
                              />
                            </svg>
                            <span>{q.score}</span>
                          </div>
                        </div>
                        {col.id === 'draft' && (
                          <div class="lead-step-bar" aria-label={`Passo ${formStep + 1} de ${FORM_STEPS}`}>
                            <div class="lead-step-bar__fill" style={`width: ${((formStep + 1) / FORM_STEPS) * 100}%`} />
                            <span>Passo {formStep + 1}/{FORM_STEPS}</span>
                          </div>
                        )}
                        <dl class="lead-mini-card__meta">
                          <div><dt>E-mail</dt><dd>{text(lead.email)}</dd></div>
                          {shortClub !== '-' && <div><dt>Club</dt><dd>{shortClub}</dd></div>}
                          {q.revenue !== '-' && <div><dt>Faturamento</dt><dd>{q.revenue}</dd></div>}
                        </dl>
                        <footer class="lead-mini-card__footer">
                          <time datetime={String(lead.submitted_at)}>{formatShortDate(lead.submitted_at)}</time>
                          <div class="lead-card-actions">
                            {whatsappUrl ? (
                              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a>
                            ) : (
                              <span class="lead-mini-card__muted">Sem WhatsApp</span>
                            )}
                            <button type="button" class="lead-delete-btn" data-lead-delete aria-label={`Excluir ${displayName}`}>
                              Excluir
                            </button>
                          </div>
                        </footer>
                      </article>
                    );
                  })
                )}
              </div>
            </div>
          );
        })}
      </section>
    ) : (
      <section class="lead-list" aria-label="Lista de leads">
        {leads.length === 0 ? (
          <div class="lead-empty admin-card">
            <h2>Nenhum lead neste filtro</h2>
            <p>Quando novas candidaturas chegarem, elas aparecem aqui.</p>
            <a href={buildLeadsHref({ status: 'all', view: 'list' })} class="lead-link">Ver todos os leads</a>
          </div>
        ) : (
          leads.map((lead) => {
            const q = getQualification(lead);
            const source = parseLeadSource(typeof lead.source === 'string' ? lead.source : '');
            const effectiveStatus = getEffectiveStatus(lead);
            const displayName = text(lead.name, effectiveStatus === 'draft' ? '(sem nome)' : '-');
            const initials = getInitials(displayName, text(lead.email));
            const whatsapp = text(lead.phone);
            const whatsappUrl = whatsapp !== '-' ? `https://wa.me/${whatsapp.replace(/\D/g, '')}` : '';
            const notes = parseLeadNotes(lead.notes);
            const formStep = Number(notes.form_step ?? 0);
            const club = text(lead.evento_interesse);
            const cnpj = text(lead.cnpj ?? notes.cnpj);

            return (
              <article class="lead-card" data-draft={effectiveStatus === 'draft' ? 'true' : undefined} data-priority={q.priority} data-lead-id={String(lead.id)}>
                <div class="lead-card__hero">
                  <div class="lead-avatar lead-avatar--lg" aria-hidden="true">{initials}</div>
                  <div class="lead-card__intro">
                    <div class="lead-card__title-row">
                      <h2 class="lead-card__name">{displayName}</h2>
                      <div class="lead-score lead-score--lg" data-score={q.score} title={`Score ${q.score}`}>
                        <svg viewBox="0 0 36 36" aria-hidden="true">
                          <circle class="lead-score__track" cx="18" cy="18" r="15.5" />
                          <circle class="lead-score__fill" cx="18" cy="18" r="15.5" style={`stroke-dasharray: ${q.score} 100; stroke: ${scoreColor(q.score)}`} />
                        </svg>
                        <span>{q.score}</span>
                      </div>
                    </div>
                    <p class="lead-card__company">
                      {text(lead.company, effectiveStatus === 'draft' ? 'Empresa não informada' : '-')}
                      · {text(lead.role, effectiveStatus === 'draft' ? 'Cargo pendente' : '-')}
                    </p>
                    <div class="lead-card__badges">
                      <span data-brand={source.brand}>{getLeadBrandLabel(source.brand)}</span>
                      <span data-priority={q.priority}>{priorityLabels[q.priority] ?? q.priority}</span>
                      <span data-status={effectiveStatus}>{statusLabels[effectiveStatus] ?? effectiveStatus}</span>
                      {effectiveStatus === 'draft' && <span data-draft-badge>Passo {formStep + 1}/{FORM_STEPS}</span>}
                    </div>
                    {effectiveStatus === 'draft' && (
                      <div class="lead-step-bar lead-step-bar--wide" aria-label={`Passo ${formStep + 1} de ${FORM_STEPS}`}>
                        <div class="lead-step-bar__fill" style={`width: ${((formStep + 1) / FORM_STEPS) * 100}%`} />
                      </div>
                    )}
                  </div>
                </div>

                <dl class="lead-card__grid">
                  <div><dt>E-mail</dt><dd>{text(lead.email)}</dd></div>
                  <div><dt>Club</dt><dd>{club}</dd></div>
                  <div><dt>CNPJ</dt><dd>{cnpj}</dd></div>
                  <div>
                    <dt>WhatsApp</dt>
                    <dd>
                      {whatsappUrl ? (
                        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="lead-wa-link">{whatsapp}</a>
                      ) : whatsapp}
                    </dd>
                  </div>
                  <div><dt>Faturamento</dt><dd>{q.revenue}</dd></div>
                  <div><dt>Colaboradores</dt><dd>{q.employees}</dd></div>
                  <div><dt>Momento</dt><dd>{q.moment}</dd></div>
                  <div><dt>Origem</dt><dd>{formatLeadSourceLabel(source)}</dd></div>
                </dl>

                {q.objective !== '-' && <p class="lead-card__objective">{q.objective}</p>}

                <footer class="lead-card__footer">
                  <span>Recebido em {formatDate(lead.submitted_at)}</span>
                  <div class="lead-card-actions">
                    {whatsappUrl && (
                      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="lead-wa-btn">Abrir WhatsApp</a>
                    )}
                    <button type="button" class="lead-delete-btn" data-lead-delete aria-label={`Excluir ${displayName}`}>
                      Excluir card
                    </button>
                  </div>
                </footer>
              </article>
            );
          })
        )}
      </section>
    )}
  </>
  )}
</AdminLayout>

<script>
  const deleteButtons = document.querySelectorAll('[data-lead-delete]');

  deleteButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      const card = button.closest('[data-lead-id]');
      const leadId = card?.getAttribute('data-lead-id');
      if (!leadId) return;

      const leadName =
        card?.querySelector('.lead-card__name, .lead-mini-card__name')?.textContent?.trim() || 'este lead';

      if (!window.confirm(`Excluir permanentemente ${leadName}? Esta ação não pode ser desfeita.`)) {
        return;
      }

      button.setAttribute('disabled', 'true');

      try {
        const response = await fetch('/api/admin/leads', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'delete', id: leadId }),
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(typeof payload.error === 'string' ? payload.error : 'Não foi possível excluir.');
        }

        card?.remove();

        const emptyColumn = document.querySelector('.lead-column__cards:not(:has(.lead-mini-card))');
        emptyColumn?.querySelector('.lead-column__empty')?.remove();
        if (emptyColumn && !emptyColumn.querySelector('.lead-mini-card')) {
          const empty = document.createElement('p');
          empty.className = 'lead-column__empty';
          empty.textContent = 'Nenhum lead aqui';
          emptyColumn.appendChild(empty);
        }
      } catch (error) {
        button.removeAttribute('disabled');
        const message = error instanceof Error ? error.message : 'Não foi possível excluir o lead.';
        window.alert(message);
      }
    });
  });
</script>

<style>
  .lead-header {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: flex-end;
    margin-bottom: 1.5rem;
  }

  .lead-eyebrow {
    color: var(--mb-yellow);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .lead-header h1 {
    color: var(--mb-white);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .lead-header p {
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.6rem;
    max-width: 32rem;
    font-size: 0.92rem;
  }

  .lead-header__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .lead-view-toggle {
    display: inline-flex;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 0.2rem;
    gap: 0.15rem;
  }

  .lead-view-toggle a,
  .lead-filters a,
  .lead-link {
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .lead-view-toggle a {
    padding: 0.5rem 0.85rem;
  }

  .lead-view-toggle a[aria-current='page'] {
    background: var(--mb-yellow);
    color: var(--mb-black);
  }

  .lead-link {
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.55rem 0.9rem;
  }

  .lead-link:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--mb-white);
  }

  .lead-metrics {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.65rem;
    margin-bottom: 1rem;
  }

  .lead-metric {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.85rem 0.9rem;
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .lead-metric:hover,
  .lead-metric[data-active='true'] {
    border-color: rgba(251, 190, 10, 0.45);
    background: rgba(251, 190, 10, 0.08);
  }

  .lead-metric__value {
    display: block;
    color: var(--mb-white);
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1;
  }

  .lead-metric__label {
    display: block;
    margin-top: 0.3rem;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.72rem;

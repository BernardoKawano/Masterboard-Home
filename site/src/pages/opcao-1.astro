---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: '800+', label: 'membros ativos' },
  { value: '120h', label: 'de prática aplicada' },
  { value: '12+', label: 'encontros estratégicos' },
  { value: '100%', label: 'professores do mercado' },
];

const reasons = [
  {
    icon: 'verified',
    title: 'Certificação MEC',
    text: 'MBA próprio com credibilidade acadêmica e foco em aplicação executiva.',
  },
  {
    icon: 'groups',
    title: 'Turmas reduzidas',
    text: 'Aprendizado individualizado, conversas profundas e troca qualificada.',
  },
  {
    icon: 'hub',
    title: 'Networking de alto nível',
    text: 'Conexão direta com líderes, empreendedores e decisores do ecossistema.',
  },
  {
    icon: 'track_changes',
    title: 'Projeto aplicado',
    text: 'Cada módulo gera decisões, rituais e experimentos para o negócio real.',
  },
];

const steps = [
  {
    title: 'Inscrição',
    text: 'Preencha o formulário e conte seu momento, desafios e objetivos.',
  },
  {
    title: 'Seleção',
    text: 'Avaliamos experiência, perfil executivo e aderência à turma.',
  },
  {
    title: 'Comece o MBA',
    text: 'Integre a turma e inicie uma jornada prática com pares qualificados.',
  },
];

const speakers = [
  { name: 'Ana Ribeiro', role: 'Estratégia e crescimento' },
  { name: 'Bruno Martins', role: 'Finanças e M&A' },
  { name: 'Carla Mendes', role: 'Liderança executiva' },
  { name: 'Daniel Costa', role: 'Marketing e posicionamento' },
  { name: 'Eduarda Lima', role: 'Operações e escala' },
  { name: 'Felipe Rocha', role: 'Governança e conselho' },
  { name: 'Gabriela Torres', role: 'Inovação e tecnologia' },
  { name: 'Henrique Alves', role: 'Vendas B2B' },
];

const programPoints = [
  'Diagnóstico estratégico da empresa',
  'Decisão orientada por dados e contexto',
  'Governança, conselho e sucessão',
  'Crescimento, capital e novas oportunidades',
  'Comunicação executiva e influência',
];

const practiceCards = [
  {
    icon: 'school',
    title: 'Teoria que vira decisão',
    text: 'Conteúdo acadêmico conectado a dilemas reais de liderança e gestão.',
  },
  {
    icon: 'bolt',
    title: 'Ritmo executivo',
    text: 'Módulos desenhados para quem precisa aprender sem pausar a operação.',
  },
  {
    icon: 'rocket_launch',
    title: 'Aplicação entre módulos',
    text: 'Ferramentas, provocações e acompanhamento para testar no próprio negócio.',
  },
];

const compactFaqs = [
  {
    question: 'Para quem é o MBA Masterboard?',
    answer:
      'Para fundadores, CEOs, diretores e líderes que já carregam decisões relevantes e buscam evoluir com pares no mesmo nível.',
  },
  {
    question: 'O MBA é apenas teórico?',
    answer:
      'Não. A proposta combina fundamentos, casos reais, discussões entre pares e aplicação prática entre os módulos.',
  },
  {
    question: 'Como funciona a seleção?',
    answer:
      'A entrada passa por curadoria para manter a qualidade da turma, o nível das conversas e a troca estratégica.',
  },
  {
    question: 'Existe certificado?',
    answer:
      'Sim. A jornada foi pensada como MBA próprio, com credibilidade acadêmica e orientação ao mercado.',
  },
];

const mbaFaqs = [
  ...compactFaqs,
  {
    question: 'Qual é o diferencial do Masterboard?',
    answer:
      'Além do conteúdo, o participante acessa uma rede empresarial ativa, com experiências, conexões e conversas que continuam além da sala de aula.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: mbaFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout
  title="MBA Masterboard | Formação executiva para líderes"
  description="MBA Masterboard é uma formação executiva prática para líderes que querem acelerar decisões, estratégia e conexões com o mercado real."
  ogImage="/images/bg-banner.png"
  noindex={true}
  jsonLd={[faqSchema]}
>
  <Header />

  <main id="main-content" class="mba-page">
    <section class="mba-hero" aria-labelledby="mba-hero-title">
      <div class="mba-hero__grid" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="mba-hero__content container">
        <div class="mba-hero__copy" data-animate>
          <img
            src="/brand/masterboard-logo-light.png"
            alt="Masterboard"
            class="mba-hero__logo"
            width="2001"
            height="176"
            loading="eager"
            decoding="async"
          />
          <h1 id="mba-hero-title">
            <span>MBA</span>
            <strong>Master</strong>
          </h1>
          <p>
            Acelere sua trajetória com um MBA orientado à prática. Aprenda com especialistas do mercado e desenvolva competências para liderar em cenários reais.
          </p>
          <a href="/aplicacao/" class="mba-button mba-button--yellow">
            Faça parte do club
            <span class="material-symbols-rounded" aria-hidden="true">arrow_outward</span>
          </a>
        </div>

        <div class="mba-hero__visual" data-animate-scale aria-hidden="true">
          <div class="mba-hero__photo">
            <img
              src="/images/bg-banner-1280.webp"
              alt=""
              width="1200"
              height="900"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <div class="mba-floating-card mba-floating-card--top">
            <span class="material-symbols-rounded" aria-hidden="true">workspace_premium</span>
            Certificação e prática
          </div>
          <div class="mba-floating-card mba-floating-card--bottom">
            <strong>100%</strong>
            professores do mercado
          </div>
        </div>
      </div>

      <div class="mba-marquee" aria-hidden="true">
        <div>
          CURADORIA ATIVA - REDE DE ALTO NIVEL - ACESSO DIRETO A QUEM DECIDE - BOARD SELECIONADO - MATCH ESTRATEGICO - RELACIONAMENTOS QUE VIRAM PARCERIAS -
          CURADORIA ATIVA - REDE DE ALTO NIVEL - ACESSO DIRETO A QUEM DECIDE - BOARD SELECIONADO - MATCH ESTRATEGICO - RELACIONAMENTOS QUE VIRAM PARCERIAS -
        </div>
      </div>
    </section>

    <section class="mba-stats" aria-label="Números do MBA">
      <div class="container">
        <div class="mba-stats__grid">
          {stats.map((stat) => (
            <article class="mba-stat" data-animate>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mba-intro" aria-labelledby="mba-intro-title">
      <div class="container">
        <p class="mba-kicker" data-animate>Formação executiva Masterboard</p>
        <div class="mba-split">
          <h2 id="mba-intro-title" data-animate data-animate-delay="100">
            Um MBA para quem precisa transformar conhecimento em decisão.
          </h2>
          <p data-animate data-animate-delay="150">
            A experiência combina aulas com especialistas, discussões em grupos selecionados e desafios aplicados ao contexto de cada líder. O objetivo é formar repertório, clareza estratégica e conexões que seguem depois da sala.
          </p>
        </div>
      </div>
    </section>

    <section class="mba-orbit" aria-labelledby="mba-reasons-title">
      <div class="container">
        <div class="mba-section-heading mba-section-heading--center" data-animate>
          <h2 id="mba-reasons-title">Por que escolher o MBA Masterboard?</h2>
          <p>O MBA Masterboard forma líderes com visão estratégica, aplicação prática e conexão com o mercado real.</p>
        </div>

        <div class="mba-orbit__stage" data-animate-scale>
          <div class="mba-orbit__rings" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="mba-phone" aria-hidden="true">
            <img src="/images/bg-banner-768.webp" alt="" width="420" height="680" loading="lazy" fetchpriority="low" decoding="async" />
          </div>

          {reasons.map((reason, index) => (
            <article class={`mba-reason-card mba-reason-card--${index + 1}`}>
              <span class="material-symbols-rounded" aria-hidden="true">{reason.icon}</span>
              <h3>{reason.title}</h3>
              <p>{reason.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mba-process" aria-labelledby="mba-process-title">
      <div class="container">
        <div class="mba-section-heading mba-section-heading--center" data-animate>
          <h2 id="mba-process-title">Como funciona?</h2>
          <p>Um processo simples e criterioso, feito para líderes que buscam resultado real.</p>
        </div>

        <div class="mba-steps">
          {steps.map((step, index) => (
            <article class="mba-step" data-animate data-animate-delay={String(100 + index * 80)}>
              <span>{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mba-speakers" aria-labelledby="mba-speakers-title">
      <div class="container">
        <p class="mba-kicker" data-animate>Especialistas convidados</p>
        <div class="mba-split">
          <h2 id="mba-speakers-title" data-animate data-animate-delay="100">
            Aprenda com quem decide, executa e já enfrentou cenários reais.
          </h2>
          <p data-animate data-animate-delay="150">
            Professores e convidados trazem casos, frameworks e provocações para elevar a qualidade das decisões da turma.
          </p>
        </div>
      </div>

      <div class="mba-speaker-rail" tabindex="0" aria-label="Lista horizontal de especialistas">
        {speakers.map((speaker) => (
          <article class="mba-speaker-card">
            <div class="mba-speaker-card__avatar" aria-hidden="true">
              <span>{speaker.name.split(' ').map((part) => part[0]).join('')}</span>
            </div>
            <h3>{speaker.name}</h3>
            <p>{speaker.role}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mba-quote" aria-labelledby="mba-quote-title">
      <div class="container">
        <p class="mba-kicker" id="mba-quote-title">Depoimento</p>
        <blockquote>
          "A metodologia do MBA incentiva que cada aprendizado seja aplicado entre os módulos, permitindo testar estratégias no próprio negócio."
        </blockquote>
        <figcaption>
          <strong>Ian Klein</strong>
          <span>Empresário e mentor convidado</span>
        </figcaption>
      </div>
    </section>

    <section class="mba-program" aria-labelledby="mba-program-title">
      <div class="container">
        <div class="mba-program__image" data-animate-scale>
          <img src="/images/bg-banner-1280.webp" alt="Encontro executivo Masterboard" width="900" height="1000" loading="lazy" fetchpriority="low" decoding="async" />
          <div class="mba-program__badge">
            <span class="material-symbols-rounded" aria-hidden="true">call_split</span>
            <div>
              <small>New invitation</small>
              <strong>Interview invitation</strong>
            </div>
          </div>
        </div>

        <div class="mba-program__content" data-animate>
          <p class="mba-kicker">Jornada aplicada</p>
          <h2 id="mba-program-title">Razões para escolher um MBA conectado ao mercado.</h2>
          <p>
            O programa foi desenhado para líderes que precisam aprender, decidir e aplicar com velocidade. Cada encontro aproxima repertório acadêmico de desafios reais de gestão.
          </p>
          <ul>
            {programPoints.map((point) => (
              <li>
                <span class="material-symbols-rounded" aria-hidden="true">check</span>
                {point}
              </li>
            ))}
          </ul>
          <div class="mba-actions">
            <a href="/aplicacao/" class="mba-button mba-button--dark">Faça parte do club</a>
            <a class="mba-button mba-button--outline" href="#mba-faq">Ver FAQs</a>
          </div>
        </div>
      </div>
    </section>

    <section class="mba-practice" aria-labelledby="mba-practice-title">
      <div class="container">
        <div class="mba-section-heading mba-section-heading--center" data-animate>
          <h2 id="mba-practice-title">Muito além da teoria</h2>
        </div>

        <div class="mba-practice__grid">
          {practiceCards.map((card, index) => (
            <article class="mba-practice-card" data-animate data-animate-delay={String(100 + index * 80)}>
              <span class="material-symbols-rounded" aria-hidden="true">{card.icon}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mba-faq-preview" aria-labelledby="mba-preview-title">
      <div class="container">
        <div class="mba-faq-preview__image" data-animate-scale>
          <img src="/images/bg-banner-1280.webp" alt="Executivos em discussão estratégica" width="880" height="1000" loading="lazy" fetchpriority="low" decoding="async" />
        </div>

        <div class="mba-faq-preview__content" data-animate>
          <h2 id="mba-preview-title">Perguntas antes da candidatura</h2>
          <p>Entenda se a jornada combina com seu momento antes de solicitar acesso à próxima turma.</p>
          <div class="mba-accordion">
            {compactFaqs.map((faq, index) => (
              <details open={index === 0}>
                <summary>
                  <span>{faq.question}</span>
                  <span class="material-symbols-rounded" aria-hidden="true">add</span>
                </summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
          <a href="/aplicacao/" class="mba-button mba-button--dark">
            Solicitar conversa
          </a>
        </div>
      </div>
    </section>

    <section class="mba-testimonial" aria-labelledby="mba-testimonial-title">
      <div class="container">
        <p class="mba-kicker" data-animate>Experiência da turma</p>
        <div class="mba-split">
          <h2 id="mba-testimonial-title" data-animate data-animate-delay="100">
            Uma formação para evoluir estratégia, liderança e relações.
          </h2>
          <p data-animate data-animate-delay="150">
            O MBA foi pensado para unir repertório, prática e comunidade em uma experiência objetiva para líderes em movimento.
          </p>
        </div>

        <div class="mba-testimonial__card" data-animate-scale>
          <div class="mba-testimonial__text">
            <blockquote>
              A metodologia do MBA incentiva que cada aprendizado seja aplicado entre os módulos, permitindo testar estratégias no próprio negócio.
            </blockquote>
            <div class="mba-testimonial__arrows" aria-hidden="true">
              <span class="material-symbols-rounded">arrow_back</span>
              <span class="material-symbols-rounded">arrow_forward</span>
            </div>
          </div>
          <div class="mba-testimonial__video" aria-hidden="true">
            <img src="/images/bg-banner-768.webp" alt="" width="700" height="700" loading="lazy" fetchpriority="low" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <section id="mba-faq" class="mba-faq" aria-labelledby="mba-faq-title">
      <div class="container">
        <h2 id="mba-faq-title" data-animate>MBA FAQs</h2>
        <div class="mba-faq__list" data-animate data-animate-delay="100">
          {mbaFaqs.map((faq, index) => (
            <details open={index === 0}>
              <summary>
                <span>{String(index + 1).padStart(2, '0')}.</span>
                <strong>{faq.question}</strong>
                <span class="material-symbols-rounded" aria-hidden="true">add</span>
              </summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="mba-final-cta" aria-labelledby="mba-final-title">
      <div class="mba-final-cta__inner">
        <h2 id="mba-final-title">Pronto para fazer parte do MBA Masterboard?</h2>
        <a href="/aplicacao/" class="mba-button mba-button--light">
          Faça parte do club
          <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  :global(body) {
    background: #f9fbfd;
  }

  .mba-page {
    background: #f9fbfd;
    color: #0d0d0d;
    overflow: hidden;
  }

  .mba-page :global(.container) {
    max-width: 1280px;
  }

  .mba-hero {
    position: relative;
    min-height: 811px;
    background: #111111;
    color: #ffffff;
    isolation: isolate;
    overflow: hidden;
  }

  .mba-hero__grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    pointer-events: none;
    z-index: -1;
  }

  .mba-hero__grid span {
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mba-hero__content {
    min-height: 811px;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.82fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    padding-top: 5rem;
    padding-bottom: 7rem;
  }

  .mba-hero__copy {
    max-width: 540px;
    padding-left: clamp(0rem, 8vw, 8.5rem);
  }

  .mba-hero__logo {
    width: 141px;
    height: auto;
    margin-bottom: 3rem;
  }

  .mba-hero h1 {
    margin: 0;
    font-size: clamp(4.4rem, 9vw, 6.25rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .mba-hero h1 span,
  .mba-hero h1 strong {
    display: block;
    font-weight: 800;
  }

  .mba-hero h1 strong {
    color: #fbbe0a;
  }

  .mba-hero p {
    max-width: 460px;
    margin: 3rem 0 2rem;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.35;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.88);
  }

  .mba-hero__visual {
    position: relative;
    min-height: 640px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: #252525;
    overflow: hidden;
  }

  .mba-hero__photo {
    position: absolute;
    inset: 0;
  }

  .mba-hero__photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(17, 17, 17, 0.92), rgba(17, 17, 17, 0.2) 42%, rgba(251, 190, 10, 0.18)),
      radial-gradient(circle at 70% 30%, rgba(251, 190, 10, 0.28), transparent 38%);
  }

  .mba-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    filter: grayscale(0.25) contrast(1.08);
  }

  .mba-floating-card {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(13, 13, 13, 0.72);
    color: #ffffff;
    padding: 1rem;
    box-shadow: 0 32px 64px -12px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(18px);
  }

  .mba-floating-card .material-symbols-rounded {
    color: #fbbe0a;
  }

  .mba-floating-card--top {
    top: 17%;
    left: -2rem;
  }

  .mba-floating-card--bottom {
    right: 2rem;
    bottom: 7rem;
    flex-direction: column;
    align-items: flex-start;
  }

  .mba-floating-card--bottom strong {
    color: #fbbe0a;
    font-size: 2rem;
    line-height: 1;
  }

  .mba-marquee {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 65px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #000000;
  }

  .mba-marquee div {
    min-width: max-content;
    padding-left: 2rem;
    color: #ffffff;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: 0.04em;
    animation: mba-marquee 36s linear infinite;
  }

  .mba-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 56px;
    padding: 1rem 1.875rem;
    border: 0;
    border-radius: 999px;
    font: inherit;
    font-weight: 600;
    line-height: 1.25;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .mba-button:hover {
    transform: translateY(-2px);
  }

  .mba-button--yellow {
    background: #fbbe0a;
    color: #0d0d0d;
    box-shadow: 0 18px 40px rgba(251, 190, 10, 0.24);
  }

  .mba-button--dark {
    background: #0d0d0d;
    color: #f2f2f1;
  }

  .mba-button--outline {
    border: 1px solid #0d0d0d;
    background: transparent;
    color: #0d0d0d;
  }

  .mba-button--light {
    background: #f9fbfd;
    color: #0d0d0d;
  }

  .mba-stats {
    padding: 5rem 0;
  }

  .mba-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 4vw, 2.5rem);
  }

  .mba-stat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .mba-stat strong {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #09090b;
  }

  .mba-stat span {
    max-width: 110px;
    color: #09090b;
    font-size: 1rem;
    line-height: 1.5;
  }

  .mba-intro,
  .mba-speakers,
  .mba-testimonial {
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .mba-kicker {
    margin: 0 0 2.5rem;
    color: #1a1a1a;
    font-size: 0.875rem;

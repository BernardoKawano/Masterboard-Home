---
const timelineItems = [
  {
    step: '01',
    label: 'Metodologia',
    title: 'Sistema Scale de vendas B2B',
    description: 'Do ICP à governança de receita — um ciclo completo e replicável. Construído por quem fez, não por quem só ensina. Sem intuição, com sistema.',
  },
  {
    step: '02',
    label: 'Educação continuada',
    title: 'Módulos trimestrais com quem viveu',
    description: 'A cada trimestre, um novo tema: escala, liderança, financeiro, M&A, operações. Conteúdo denso, sem enrolação. Formato feito para quem não tem tempo a perder.',
  },
  {
    step: '03',
    label: 'Aprendizado presencial',
    title: 'Mesas, imersões e jantares privados',
    description: 'Encontros onde o aprendizado acontece pela conversa real — sem pitch, sem palco. Grupos reduzidos, contexto compartilhado, decisões que mudam o negócio.',
  },
  {
    step: '04',
    label: 'Rede com filtro',
    title: '~200 membros selecionados',
    description: 'A entrada começa por análise de perfil. A régua protege o tempo de quem já está dentro — e eleva o valor de cada troca. Qualidade, não volume.',
  },
  {
    step: '05',
    label: 'Acesso contínuo',
    title: 'Comunidade ativa além dos encontros',
    description: 'App exclusivo, matchmaking com contexto e capítulos nacionais. O ecossistema funciona todos os dias — não só nos eventos.',
  },
];
---

<section
  id="experiencias"
  class="section-py section-ambient relative"
  style="overflow: visible;"
  aria-labelledby="ecosystem-heading"
>
  <div class="section-ambient__backdrop" aria-hidden="true">
    <div class="mb-glow-orb mb-glow-orb--top-right"></div>
    <div class="mb-glow-orb mb-glow-orb--bottom-left"></div>
  </div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="container relative z-10">

    <div class="grid grid-cols-1 lg:grid-cols-[0.78fr_1.22fr] gap-8 lg:gap-12 items-start">
      <!-- Cabeçalho — sticky no desktop, estático no mobile -->
      <div class="max-w-xl lg:sticky lg:top-28 lg:self-start">
        <p class="eyebrow mb-4" data-animate>Como funciona</p>
        <h2
          id="ecosystem-heading"
          class="section-title text-balance"
          data-animate
          data-animate-delay="100"
        >
          Método, rede e conteúdo
          <span class="text-mb-yellow"> num só lugar.</span>
        </h2>
        <p class="text-white/55 mt-4 leading-relaxed" data-animate data-animate-delay="150">
          Não é curso. Não é evento. É um ecossistema de educação contínua onde metodologia, comunidade e aprendizado ao vivo se combinam para que você decida melhor — e mais rápido.
        </p>
        <div class="mt-6" data-animate data-animate-delay="200">
          <a href="/aplicacao/" class="btn-primary w-full sm:w-auto justify-center">
            Quero participar
          </a>
        </div>
      </div>

      <!-- Timeline de experiências -->
      <div class="experience-timeline relative pl-8 md:pl-10" data-animate data-animate-delay="200">
        <div
          class="experience-timeline__rail absolute left-3 md:left-4 top-2 bottom-2 w-px"
          aria-hidden="true"
        ></div>

        <div class="space-y-4 md:space-y-5">
          {timelineItems.map((item, i) => (
            <article
              class="experience-timeline__card relative rounded-2xl p-5 md:p-6 transition-all"
              data-animate
              data-animate-delay={String(240 + i * 80)}
            >
              <div
                class="experience-timeline__marker absolute -left-[2.35rem] md:-left-[2.6rem] top-6 flex h-7 w-7 items-center justify-center rounded-full text-[10px] font-800"
                aria-hidden="true"
              >
                {item.step}
              </div>

              <p class="experience-timeline__label text-[11px] uppercase tracking-[0.22em] mb-3">
                {item.label}
              </p>
              <h3 class="text-white font-800 text-xl md:text-2xl leading-tight tracking-tight mb-3">
                {item.title}
              </h3>
              <p class="text-white/56 text-sm md:text-base leading-relaxed max-w-2xl">
                {item.description}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .experience-timeline__rail {
    background: linear-gradient(
      180deg,
      rgba(251, 190, 10, 0.46) 0%,
      rgba(251, 190, 10, 0.18) 42%,
      rgba(255, 255, 255, 0.08) 78%,
      transparent 100%
    );
  }

  .experience-timeline__card {
    border: 1px solid rgba(255, 255, 255, 0.085);
    background:
      linear-gradient(135deg, rgba(251, 190, 10, 0.055) 0%, rgba(255, 255, 255, 0.032) 34%, rgba(255, 255, 255, 0.018) 100%),
      rgba(0, 0, 0, 0.38);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.055),
      0 18px 48px rgba(0, 0, 0, 0.22);
  }

  .experience-timeline__card:hover {
    border-color: rgba(251, 190, 10, 0.24);
    background:
      linear-gradient(135deg, rgba(251, 190, 10, 0.08) 0%, rgba(255, 255, 255, 0.04) 38%, rgba(255, 255, 255, 0.022) 100%),
      rgba(0, 0, 0, 0.42);
    transform: translateY(-2px);
  }

  .experience-timeline__marker {
    border: 1px solid rgba(251, 190, 10, 0.34);
    background: linear-gradient(180deg, rgba(251, 190, 10, 0.18), rgba(251, 190, 10, 0.08)), var(--mb-black);
    color: rgba(251, 190, 10, 0.9);
    box-shadow:
      0 0 0 6px rgba(0, 0, 0, 0.92),
      0 0 24px rgba(251, 190, 10, 0.12);
  }

  .experience-timeline__label {
    color: rgba(251, 190, 10, 0.62);
  }
</style>

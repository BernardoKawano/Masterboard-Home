---
const navLinks = [
  { href: '/#sobre', label: 'Sobre' },
  { href: '/eventos/', label: 'Eventos' },
  { href: '/blog/', label: 'Blog' },
  { href: 'https://app.masterboard.com.br/galeria', label: 'Galeria', external: true },
  { href: 'https://app.masterboard.com.br', label: 'App', external: true },
];
---

<header class="site-header" role="banner">
  <div class="container">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo lockup oficial (wordmark + M) -->
      <a href="/" aria-label="Masterboard — página inicial" class="brand-lockup">
        <img
          src="/brand/masterboard-logo-header.png"
          alt="Masterboard"
          class="brand-logo brand-logo--header"
          width="420"
          height="52"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Menu principal">
        {navLinks.map(({ href, label, external }) => (
          <a
            href={href}
            class="px-4 py-2 rounded-lg text-sm font-600 text-white/70 hover:text-white hover:bg-white/5 transition-colors duration-200"
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- CTA desktop + toggle mobile -->
      <div class="flex items-center gap-3">
        <a
          href="/aplicacao/"
          class="btn-primary hidden sm:inline-flex text-sm py-2.5 px-5"
          aria-label="Abrir candidatura ao Masterboard"
        >
          Quero participar
        </a>

        <button
          type="button"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg border border-mb-border text-white/70 hover:text-white hover:border-white/20 transition-colors"
          data-menu-btn
          aria-label="Abrir menu de navegação"
          aria-expanded="false"
          aria-controls="nav-mobile"
        >
          <svg data-menu-icon-open class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg data-menu-icon-close class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav
    id="nav-mobile"
    class="nav-mobile md:hidden"
    data-nav-mobile
    aria-label="Menu mobile"
  >
    {navLinks.map(({ href, label, external }) => (
      <a
        href={href}
        class="px-4 py-3 rounded-lg text-sm font-600 text-white/80 hover:text-white hover:bg-white/5 transition-colors"
        {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {label}
      </a>
    ))}
    <div class="mt-2 pt-2 border-t border-mb-border">
      <a href="/aplicacao/" class="btn-primary w-full justify-center">
        Quero participar
      </a>
    </div>
  </nav>
</header>

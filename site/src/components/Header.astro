---
const navLinks = [
  { href: '/#sobre', label: 'Sobre' },
  { href: '/eventos/', label: 'Eventos' },
  { href: '/blog/', label: 'Blog' },
  { href: 'https://app.masterboard.com.br/galeria', label: 'Galeria', external: true },
  { href: 'https://app.masterboard.com.br', label: 'App', external: true },
];
---

<header class="site-header" role="banner">
  <div class="container">
    <div class="header-bar">

      <!-- Logo — desktop: esquerda / mobile: esquerda com placeholder à direita -->
      <a href="/" aria-label="Masterboard — página inicial" class="brand-lockup header-logo">
        <img
          src="/brand/masterboard-logo-04.png"
          alt="Masterboard"
          class="brand-logo brand-logo--header"
          width="2001"
          height="176"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Nav desktop — verdadeiramente centrada via margin auto -->
      <nav class="header-nav" aria-label="Menu principal">
        {navLinks.map(({ href, label, external }) => (
          <a
            href={href}
            class="header-nav__link"
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- CTA desktop + toggle mobile -->
      <div class="header-end">
        <a
          href="/aplicacao/"
          class="btn-primary header-cta text-sm py-2.5 px-5"
          aria-label="Abrir candidatura ao Masterboard"
        >
          Quero participar
        </a>

        <button
          type="button"
          class="header-menu-btn"
          data-menu-btn
          aria-label="Abrir menu de navegação"
          aria-expanded="false"
          aria-controls="nav-mobile"
        >
          <svg data-menu-icon-open class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg data-menu-icon-close class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav drawer (oculto em md+ via CSS — hamburguer não aparece em desktop) -->
  <nav
    id="nav-mobile"
    class="nav-mobile"
    data-nav-mobile
    aria-label="Menu mobile"
  >
    <div class="nav-mobile__links">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          class="nav-mobile__link"
          {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {label}
        </a>
      ))}
    </div>
    <div class="nav-mobile__cta">
      <a href="/aplicacao/" class="btn-primary w-full justify-center text-base py-3.5">
        Quero participar
      </a>
    </div>
  </nav>
</header>

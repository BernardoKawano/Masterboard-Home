---
import { getPublicSiteSettings } from '../lib/admin/settings';
import AnimatedGallery from './AnimatedGallery.astro';

const settings = await getPublicSiteSettings();
const hero = settings.home.hero;

const heroEyebrow = hero.eyebrow.trim();
const heroPill = hero.pill.trim();
const showHeroMeta = Boolean(heroEyebrow || heroPill);
const heroLines = [
  { text: hero.line1, className: 'block' },
  { text: hero.line2, className: 'block' },
  { text: hero.highlight, className: 'block text-gradient-yellow' },
  { text: hero.line3, className: 'block' },
].filter((line) => line.text.trim());

// Temporariamente oculto — altere para true para exibir o card lateral novamente
const SHOW_HERO_INTEL_CARD = false;
---

<section
  id="inicio"
  class="hero-section relative sm:min-h-screen flex flex-col sm:justify-center overflow-hidden bg-mb-black"
  aria-label="Introdução ao Masterboard"
>
  <AnimatedGallery />
  <div class="hero-image-overlay absolute inset-0" aria-hidden="true"></div>
  <div class="hero-bg absolute inset-0" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--primary" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--secondary" aria-hidden="true"></div>
  <div class="mb-glow-orb mb-glow-orb--center" aria-hidden="true"></div>

  <!-- Conteúdo -->
  <div class="container hero-container relative z-10 pt-12 sm:pt-24 pb-12 sm:pb-14 md:pt-28 md:pb-20">
    <div class:list={[
      'grid grid-cols-1 gap-10 xl:gap-16 items-end',
      SHOW_HERO_INTEL_CARD && 'xl:grid-cols-[minmax(0,1fr)_360px]',
    ]}>
      <div class="max-w-5xl">

        {showHeroMeta && (
          <div class="flex flex-wrap items-center gap-3 mb-4 md:mb-5" data-animate>
            {heroEyebrow && <p class="eyebrow">{heroEyebrow}</p>}
            {heroPill && <span class="hero-pill">{heroPill}</span>}
          </div>
        )}

        <!-- H1 principal -->
        <h1
          class="hero-headline text-white mb-5 md:mb-6"
          data-animate
          data-animate-delay="100"
        >
          {heroLines.map((line) => (
            <span class={line.className}>{line.text}</span>
          ))}
        </h1>

        <!-- Descrição -->
        <p
          class="text-white/70 font-medium leading-relaxed mb-6 md:mb-7 max-w-2xl"
          style="font-size: clamp(1rem, 1.55vw, 1.15rem);"
          data-animate
          data-animate-delay="200"
        >
          Reunimos métodos e experiências de grandes executivos para ajudar empresários a tomar melhores decisões, desenvolver times e construir negócios preparados para crescer.
        </p>

        <!-- Empresas referência -->
        <p
          class="text-white/38 text-xs font-600 tracking-[0.12em] uppercase mb-8 md:mb-9"
          data-animate
          data-animate-delay="250"
          aria-label="Empresas representadas pelos nossos membros"
        >
          {['Microsoft', 'Salesforce', 'Amazon', 'SAP', 'Azul', 'Wellhub'].map((empresa, i, arr) => (
            <>
              <span>{empresa}</span>
              {i < arr.length - 1 && <span class="mx-2 opacity-40">·</span>}
            </>
          ))}
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-col xs:flex-row gap-3 md:gap-4"
          data-animate
          data-animate-delay="300"
        >
          <a
            href={hero.primaryCtaHref}
            class="btn-primary btn-primary--magnetic"
            aria-label="Abrir candidatura ao Masterboard"
          >
            {hero.primaryCtaLabel}
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>

          <a href={hero.secondaryCtaHref} class="btn-secondary">
            {hero.secondaryCtaLabel}
          </a>
        </div>

      </div>

      {SHOW_HERO_INTEL_CARD && (
      <aside class="hero-intel-card" data-animate data-animate-delay="500" aria-label="Resumo da experiência Masterboard">
        <p class="text-xs uppercase tracking-[0.22em] text-mb-yellow/80 mb-5">Dentro da sala</p>
        <div class="space-y-5">
          {[
            ['01', 'Entrada seletiva', 'Candidatura analisada antes do acesso.'],
            ['02', 'Experiências privadas', 'Mesas, jantares e imersões com contexto real.'],
            ['03', 'Conexões contínuas', 'Matchmaking entre membros que fazem sentido.'],
          ].map(([number, title, text]) => (
            <div class="hero-intel-row">
              <span>{number}</span>
              <div>
                <p class="font-800 text-white leading-tight">{title}</p>
                <p class="text-white/45 text-sm leading-relaxed">{text}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-6 pt-5 border-t border-white/10">
          <p class="text-white/45 text-sm leading-relaxed">
            O próximo passo é simples: pedir acesso e passar pela curadoria.
          </p>
        </div>
      </aside>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
    aria-hidden="true"
  >
    <div class="w-5 h-8 rounded-full border border-white/15 flex justify-center pt-1.5">
      <div class="w-0.5 h-1.5 rounded-full bg-mb-yellow scroll-indicator-dot"></div>
    </div>
  </div>
</section>

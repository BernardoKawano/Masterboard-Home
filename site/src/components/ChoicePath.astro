---
const pillars = [
  {
    pill: 'curadoria de entrada',
    title: ['Curadoria', 'Ativa de Perfil'],
    description:
      'Selecionamos empresários com base no momento da empresa, maturidade de gestão e desafios estratégicos atuais. O ambiente começa no filtro: nem todo perfil é compatível com a mesa.',
  },
  {
    pill: 'conexões qualificadas',
    title: ['Match', 'Empresarial'],
    description:
      'Conectamos empresários por estágio de crescimento, desafios semelhantes e complementaridade de competências. O objetivo não é ampliar rede, é gerar trocas relevantes e decisões mais seguras.',
  },
  {
    pill: 'decisões estratégicas',
    title: ['Ambiente', 'Controlado'],
    description:
      'Estruturamos encontros em grupos reduzidos, com mediação qualificada e foco em execução. As conversas são direcionadas para validar movimentos estratégicos e acelerar decisões concretas.',
  },
];
---

<section
  id="o-que-fazemos"
  class="choice-section relative overflow-hidden"
  aria-labelledby="choice-heading"
>
  <div class="absolute inset-0 pointer-events-none choice-section__glow" aria-hidden="true"></div>

  <div class="container relative z-10">

    <!-- Cabeçalho -->
    <div class="max-w-3xl mb-12 md:mb-14">
      <p class="eyebrow mb-4" data-animate>// O QUE FAZEMOS:</p>
      <h2
        id="choice-heading"
        class="section-title text-balance"
        data-animate
        data-animate-delay="100"
      >
        Saiba mais sobre o
        <span class="text-mb-yellow"> Masterboard</span>
      </h2>
    </div>

    <!-- Accordion -->
    <div class="cpx-list" data-animate data-animate-delay="150">
      {pillars.map((p) => (
        <details class="cpx-item">
          <summary class="cpx-summary">
            <span class="cpx-pill">
              <span class="cpx-slash" aria-hidden="true">/</span>
              {p.pill}
              <span class="cpx-slash" aria-hidden="true">/</span>
            </span>
            <span class="cpx-chevron" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </summary>

          <div class="cpx-body">
            <h3 class="cpx-title">
              {p.title[0]}&nbsp;<span class="text-mb-yellow">{p.title[1]}</span>
            </h3>
            <p class="cpx-desc">{p.description}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

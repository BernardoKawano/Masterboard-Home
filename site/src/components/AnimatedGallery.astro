---
import { buildGalleryColumns, buildGalleryImagePaths } from '../lib/gallery-columns';

const GALLERY_IMAGE_COUNT = 21;
const GALLERY_COLUMN_COUNT = 4;

const imagePaths = buildGalleryImagePaths(GALLERY_IMAGE_COUNT, '/gallery', '.webp');
const columns = buildGalleryColumns(imagePaths, GALLERY_COLUMN_COUNT);
---

<div class="animated-gallery absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <div class="animated-gallery-stage">
    <div class="animated-gallery-grid">
      {columns.map((columnImages, columnIndex) => (
        <div class={`animated-gallery-col col-${columnIndex}`}>
          <div class="animated-gallery-track flex flex-col gap-6">
            {columnImages.map((src, imageIndex) => (
              <img
                class="animated-gallery-image"
                src={src}
                alt=""
                width={620}
                height={200}
                decoding="async"
                fetchpriority="low"
                loading={columnIndex === 0 && imageIndex < 3 ? 'eager' : 'lazy'}
              />
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

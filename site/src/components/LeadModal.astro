---
// Modal de candidatura "Faça parte do club"
// Pronto para integrar com webhook/CRM — não expõe credenciais no repo.
// Para conectar: substitua a action do form por uma rota API Astro ou endpoint externo.
---

<div
  class="modal-backdrop"
  data-modal-backdrop
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div class="modal-panel">

    <!-- Header do modal -->
    <div class="flex items-start justify-between mb-6">
      <div>
        <p class="eyebrow text-xs mb-1">Candidatura curada</p>
        <h2 id="modal-title" class="text-xl font-800 text-white leading-tight" style="letter-spacing: -0.02em;">
          Peça acesso à sala
        </h2>
        <p class="text-white/50 text-sm mt-1">
          Analisamos perfil, momento da operação e fit com a comunidade.
        </p>
      </div>
      <button
        type="button"
        class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-white/50 hover:text-white hover:bg-white/5 transition-colors ml-4 mt-0.5"
        data-modal-close
        aria-label="Fechar formulário"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Formulário -->
    <!--
      Para integrar:
      - Crie src/pages/api/candidatura.ts com método POST
      - Ou aponte action para seu webhook (HubSpot, RD Station, n8n, etc.)
      - Nunca coloque chaves de API diretamente aqui
    -->
    <form
      id="lead-form"
      method="POST"
      action="/api/candidatura"
      novalidate
      aria-label="Formulário de candidatura ao Masterboard"
    >
      <div class="flex flex-col gap-4">

        <div class="rounded-xl border border-mb-yellow/20 bg-mb-yellow/[0.07] p-4">
          <p class="text-white font-700 text-sm mb-1">Não é newsletter. É candidatura.</p>
          <p class="text-white/50 text-xs leading-relaxed">
            Se fizer sentido para os dois lados, nossa equipe chama você para a próxima conversa.
          </p>
        </div>

        <!-- Nome -->
        <div class="form-field">
          <label class="form-label" for="field-nome">
            Nome completo <span aria-hidden="true" class="text-mb-yellow">*</span>
          </label>
          <input
            id="field-nome"
            name="nome"
            type="text"
            class="form-input"
            placeholder="Seu nome completo"
            required
            autocomplete="name"
          />
        </div>

        <!-- E-mail -->
        <div class="form-field">
          <label class="form-label" for="field-email">
            E-mail profissional <span aria-hidden="true" class="text-mb-yellow">*</span>
          </label>
          <input
            id="field-email"
            name="email"
            type="email"
            class="form-input"
            placeholder="seu@email.com"
            required
            autocomplete="email"
          />
        </div>

        <!-- Telefone -->
        <div class="form-field">
          <label class="form-label" for="field-telefone">
            WhatsApp / Telefone <span aria-hidden="true" class="text-mb-yellow">*</span>
          </label>
          <input
            id="field-telefone"
            name="telefone"
            type="tel"
            class="form-input"
            placeholder="(11) 9 0000-0000"
            required
            autocomplete="tel"
          />
        </div>

        <!-- Empresa -->
        <div class="form-field">
          <label class="form-label" for="field-empresa">
            Empresa <span aria-hidden="true" class="text-mb-yellow">*</span>
          </label>
          <input
            id="field-empresa"
            name="empresa"
            type="text"
            class="form-input"
            placeholder="Nome da sua empresa"
            required
            autocomplete="organization"
          />
        </div>

        <!-- Cargo -->
        <div class="form-field">
          <label class="form-label" for="field-cargo">
            Cargo / Posição <span aria-hidden="true" class="text-mb-yellow">*</span>
          </label>
          <input
            id="field-cargo"
            name="cargo"
            type="text"
            class="form-input"
            placeholder="CEO, Fundador, Diretor..."
            required
          />
        </div>

        <!-- Intenção -->
        <fieldset class="form-field">
          <legend class="form-label">
            O que você busca agora?
          </legend>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            {[
              ['membro', 'Ser membro'],
              ['eventos', 'Eventos'],
              ['conexoes', 'Conexões'],
            ].map(([value, label], index) => (
              <label class="choice-radio">
                <input
                  name="intencao"
                  type="radio"
                  value={value}
                  checked={index === 0}
                />
                <span>{label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Cidade -->
        <div class="form-field">
          <label class="form-label" for="field-cidade">
            Cidade
          </label>
          <input
            id="field-cidade"
            name="cidade"
            type="text"
            class="form-input"
            placeholder="Sua cidade"
            autocomplete="address-level2"
          />
        </div>

        <!-- Momento -->
        <div class="form-field">
          <label class="form-label" for="field-momento">
            Momento da empresa
          </label>
          <select
            id="field-momento"
            name="momento"
            class="form-input"
          >
            <option value="">Selecione se quiser</option>
            <option value="crescimento">Crescimento acelerado</option>
            <option value="expansao">Expansão para novos mercados</option>
            <option value="reposicionamento">Reposicionamento estratégico</option>
            <option value="capital">Busca de capital ou M&A</option>
            <option value="network">Rede certa para próximos passos</option>
          </select>
        </div>

        <!-- LGPD -->
        <div class="flex items-start gap-3 mt-1">
          <input
            id="field-lgpd"
            name="lgpd"
            type="checkbox"
            class="mt-0.5 w-4 h-4 rounded accent-mb-yellow cursor-pointer flex-shrink-0"
            required
            aria-required="true"
          />
          <label for="field-lgpd" class="text-xs text-white/50 leading-relaxed cursor-pointer">
            Concordo com a
            <a href="/politica-de-privacidade/" class="text-white/70 underline hover:text-mb-yellow" target="_blank">
              Política de Privacidade
            </a>
            e autorizo o contato da equipe Masterboard. Seus dados não serão compartilhados
            com terceiros sem consentimento.
          </label>
        </div>

        <!-- Honeypot anti-spam (oculto) -->
        <div class="hidden" aria-hidden="true">
          <input name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="btn-primary w-full justify-center mt-2"
          aria-label="Enviar candidatura ao Masterboard"
        >
          Enviar para curadoria
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </button>

      </div>

      <!-- Mensagem de erro (escondida por padrão) -->
      <div
        id="form-error"
        class="hidden mt-4 p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 text-sm"
        role="alert"
        aria-live="polite"
      ></div>

      <!-- Mensagem de sucesso (escondida por padrão) -->
      <div
        id="form-success"
        class="hidden mt-4 p-3 rounded-lg bg-mb-yellow/10 border border-mb-yellow/30 text-mb-yellow text-sm"
        role="status"
        aria-live="polite"
      >
        ✓ Candidatura recebida. Se houver fit, nossa equipe entrará em contato.
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando para curadoria…';

    try {
      const data = new FormData(form);

      // Honeypot check no cliente
      if (data.get('_gotcha')) {
        return;
      }

      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
      } else {
        throw new Error('Erro no servidor');
      }
    } catch {
      errorEl!.textContent = 'Ocorreu um erro. Por favor, tente novamente ou entre em contato pelo Instagram.';
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `Enviar para curadoria <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>`;
    }
  });
</script>

---
const pillars = [
  {
    number: '01',
    title: 'Educação Continuada',
    text: 'A cada trimestre, um módulo novo. Temas que importam para quem está no comando: estratégia, escala, liderança, financeiro, M&A. Conteúdo construído com quem já viveu, não com quem só ensina.',
  },
  {
    number: '02',
    title: 'Metodologia Scale',
    text: 'Vendas não é intuição — é sistema. O Masterboard inclui acesso ao método Scale, desenvolvido para negócios B2B que querem crescer com previsibilidade. Da prospecção ao fechamento, com linguagem de dono.',
  },
  {
    number: '03',
    title: 'Rede Curada',
    text: '~200 membros ativos. Sem volume, com filtro. A entrada começa por análise de perfil, momento da empresa e fit com a comunidade. A régua existe para proteger o tempo de quem já está dentro — e o valor de cada conexão.',
  },
];
---

<section
  id="sobre"
  class="section-py bg-mb-black relative overflow-hidden section-glow"
  aria-labelledby="about-heading"
>
  <div class="brand-grid-mark" aria-hidden="true"></div>
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Texto esquerda -->
      <div>
        <p class="eyebrow mb-5" data-animate>O que você encontra aqui</p>

        <h2
          id="about-heading"
          class="section-title mb-6 text-balance"
          data-animate
          data-animate-delay="100"
        >
          Um ecossistema de educação para quem
          <span class="text-mb-yellow"> lidera negócios em crescimento.</span>
        </h2>

        <p
          class="text-white/65 text-lg leading-relaxed mb-8"
          data-animate
          data-animate-delay="200"
        >
          Metodologia aplicada, educação continuada e uma rede curada de fundadores, CEOs e executivos — tudo integrado para acelerar decisões e resultados reais.
        </p>

        <div class="flex flex-col xs:flex-row gap-3" data-animate data-animate-delay="300">
          <a
            href="/aplicacao/"
            class="btn-primary"
            aria-label="Candidatar-se ao Masterboard"
          >
            Quero participar
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#metodologia" class="btn-secondary">
            Ver a metodologia
          </a>
        </div>
      </div>

      <!-- Cards direita -->
      <div class="flex flex-col gap-4">
        {pillars.map((pillar, i) => (
          <div
            class="about-pillar-card"
            data-animate
            data-animate-delay={String(200 + i * 80)}
          >
            <span class="about-pillar-number">{pillar.number}</span>
            <h3 class="about-pillar-title">{pillar.title}</h3>
            <p class="about-pillar-text">{pillar.text}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

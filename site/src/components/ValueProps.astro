---
const tabs = [
  {
    id: '01',
    title: 'Curadoria antes do convite',
    text: 'A entrada começa por análise de perfil, momento da empresa e fit com a comunidade. A régua existe para proteger a qualidade da sala e o tempo de quem já está dentro.',
    imageAvif: '/images/value-props/curadoria.avif',
    imageWebp: '/images/value-props/curadoria.webp',
    imageAlt: 'Grafismo Masterboard para curadoria de entrada',
  },
  {
    id: '02',
    title: 'Experiências com contexto',
    text: 'Mesas privadas, jantares, imersões e visitas aproximam líderes que vivem desafios parecidos. O encontro não é genérico: cada formato nasce para gerar conversa útil e decisão melhor.',
    imageAvif: '/images/value-props/experiencias.avif',
    imageWebp: '/images/value-props/experiencias.webp',
    imageAlt: 'Grafismo Masterboard para experiências executivas',
  },
  {
    id: '03',
    title: 'Continuidade entre encontros',
    text: 'A relação não termina quando o evento acaba. Matchmaking, app exclusivo e acompanhamento da comunidade mantêm as conexões vivas entre uma mesa e outra.',
    imageAvif: '/images/value-props/continuidade.avif',
    imageWebp: '/images/value-props/continuidade.webp',
    imageAlt: 'Grafismo Masterboard para continuidade entre membros',
  },
];
---

<section
  id="sobre"
  class="section-py section-ambient relative overflow-hidden"
  aria-labelledby="vp-heading"
>
  <div class="mb-glow-orb mb-glow-orb--top-right" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-9 lg:gap-14 items-center">

      <!-- ── Coluna esquerda ─────────────────────────────── -->
      <div>
        <p
          class="text-mb-yellow/70 font-800 text-xs tracking-[0.28em] uppercase mb-4"
          data-animate
        >
          // O QUE É O MASTERBOARD
        </p>

        <h2
          id="vp-heading"
          class="vp-headline text-white text-balance mb-5"
          data-animate
          data-animate-delay="100"
        >
          Um <span class="text-gradient-yellow">club empresarial</span>
          {' '}para quem lidera negócios em crescimento.
        </h2>

        <p
          class="text-white/55 text-base leading-relaxed mb-6 max-w-sm"
          data-animate
          data-animate-delay="200"
        >
          Uma comunidade fechada de fundadores, CEOs e executivos que combina curadoria, experiências presenciais e conexões contínuas para acelerar decisões.
        </p>

        <div
          class="flex flex-col xs:flex-row gap-3"
          data-animate
          data-animate-delay="260"
        >
          <a
            href="/aplicacao/"
            class="btn-primary"
            aria-label="Abrir candidatura"
          >
            Quero participar
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#experiencias" class="btn-secondary">Ver experiências</a>
        </div>
      </div>

      <!-- ── Coluna direita: painel com abas ────────────── -->
      <div data-animate data-animate-delay="150">
        <div class="vp-panel">

          <!-- Abas numéricas -->
          <div
            class="flex border-b border-white/10 mb-5"
            role="tablist"
            aria-label="Pilares do Masterboard"
          >
            {tabs.map((tab, i) => (
              <button
                class="vp-tab-btn"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`vp-panel-${tab.id}`}
                id={`vp-tab-${tab.id}`}
                data-tab={tab.id}
              >
                {tab.id}
              </button>
            ))}
            <button
              class="vp-next-btn ml-auto"
              type="button"
              aria-label="Ver próximo pilar do Masterboard"
              data-vp-next
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Painéis de conteúdo -->
          {tabs.map((tab, i) => (
            <div
              class="vp-tab-panel"
              role="tabpanel"
              id={`vp-panel-${tab.id}`}
              aria-labelledby={`vp-tab-${tab.id}`}
              data-panel={tab.id}
              hidden={i !== 0}
            >
              <h3 class="vp-panel-title-badge font-800 text-xl mb-4 leading-tight tracking-tight">
                {tab.title}
              </h3>
              <p class="text-white/60 text-base leading-relaxed">
                {tab.text}
              </p>

              <!-- Grafismo oficial do site original -->
              <div class="vp-tab-art">
                <picture>
                  <source srcset={tab.imageAvif} type="image/avif" />
                  <img
                    src={tab.imageWebp}
                    alt={tab.imageAlt}
                    width="242"
                    height="178"
                    loading="lazy"
                    fetchpriority="low"
                    decoding="async"
                  />
                </picture>
              </div>
            </div>
          ))}

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.vp-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.vp-tab-panel');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-vp-next]');
  const tabIds = Array.from(btns).map((btn) => btn.dataset.tab).filter(Boolean);
  let activeId = tabIds[0] ?? '01';

  const setActiveTab = (id: string | undefined) => {
    if (!id || id === activeId) return;
    activeId = id;

    btns.forEach((btn) => {
      btn.setAttribute('aria-selected', String(btn.dataset.tab === id));
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.panel !== id;
    });
  };

  const goToNextTab = () => {
    if (tabIds.length <= 1) return;
    const currentIndex = Math.max(tabIds.indexOf(activeId), 0);
    const nextIndex = (currentIndex + 1) % tabIds.length;
    setActiveTab(tabIds[nextIndex]);
  };

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      setActiveTab(btn.dataset.tab);
    });
  });

  nextBtn?.addEventListener('click', goToNextTab);
</script>

<style>
  .vp-next-btn {
    display: inline-flex;
    width: 2.35rem;
    height: 2.35rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(251, 190, 10, 0.26);
    border-radius: 999px;
    background: rgba(251, 190, 10, 0.08);
    color: var(--mb-yellow);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .vp-next-btn:hover {
    border-color: rgba(251, 190, 10, 0.48);
    background: rgba(251, 190, 10, 0.14);
    transform: translateX(2px);
  }

  .vp-panel-title-badge {
    display: inline;
    padding: 0.04em 0.12em 0.08em;
    background: var(--mb-yellow);
    color: var(--mb-black);
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
</style>

---
const tabs = [
  {
    id: '01',
    title: 'Conexões estratégicas',
    text: 'Mais do que conexões, estruturamos encontros entre líderes que podem gerar negócios, abrir mercados e resolver desafios concretos. Cada interação é pensada para evoluir o nível estratégico da sua empresa.',
    image: 'https://www.masterboard.com.br/wp-content/uploads/2026/04/arte-01.png',
    imageAlt: 'Grafismo Masterboard para conexões estratégicas',
  },
  {
    id: '02',
    title: 'Acesso exclusivo',
    text: 'Um ecossistema fechado onde a qualidade começa antes de a sala ser aberta. Curadoria rigorosa, grupos reduzidos e o compromisso de que cada pessoa na sala vale o tempo de todos.',
    image: 'https://www.masterboard.com.br/wp-content/uploads/2026/04/arte-03.png',
    imageAlt: 'Grafismo Masterboard para acesso exclusivo',
  },
  {
    id: '03',
    title: 'Mentoria real',
    text: 'Acesse líderes que já passaram pelos desafios que você enfrenta hoje. Mentorias diretas, sem script, com quem está no jogo e compartilha o bastidor — não a palestra ensaiada.',
    image: 'https://www.masterboard.com.br/wp-content/uploads/2026/04/arte-02.png',
    imageAlt: 'Grafismo Masterboard para mentoria real',
  },
];
---

<section
  id="proposta"
  class="vp-scroll-lock bg-mb-black section-glow relative"
  aria-labelledby="vp-heading"
  data-vp-section
>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="container vp-scroll-sticky">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-20 items-center">

      <!-- ── Coluna esquerda ─────────────────────────────── -->
      <div>
        <p
          class="text-mb-yellow/70 font-800 text-xs tracking-[0.28em] uppercase mb-6"
          data-animate
        >
          // MASTERBOARD
        </p>

        <h2
          id="vp-heading"
          class="vp-headline text-white text-balance mb-6"
          data-animate
          data-animate-delay="100"
        >
          Um <span class="text-gradient-yellow">club empresarial</span>
          {' '}para líderes que definem o rumo do jogo.
        </h2>

        <p
          class="text-white/55 text-base leading-relaxed mb-8 max-w-sm"
          data-animate
          data-animate-delay="200"
        >
          O ecossistema fechado onde as melhores decisões são tomadas entre quem já está jogando no mesmo nível.
        </p>

        <div
          class="flex flex-col xs:flex-row gap-3"
          data-animate
          data-animate-delay="300"
        >
          <button
            type="button"
            class="btn-primary"
            data-open-modal
            aria-label="Abrir formulário de candidatura"
          >
            Faça parte do club
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </button>
          <a href="#sobre" class="btn-secondary">Saiba mais</a>
        </div>
      </div>

      <!-- ── Coluna direita: painel com abas ────────────── -->
      <div data-animate data-animate-delay="150">
        <div class="vp-panel">

          <!-- Abas numéricas -->
          <div
            class="flex border-b border-white/10 mb-7"
            role="tablist"
            aria-label="Pilares do Masterboard"
          >
            {tabs.map((tab, i) => (
              <button
                class="vp-tab-btn"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`vp-panel-${tab.id}`}
                id={`vp-tab-${tab.id}`}
                data-tab={tab.id}
              >
                {tab.id}
              </button>
            ))}
          </div>

          <!-- Painéis de conteúdo -->
          {tabs.map((tab, i) => (
            <div
              class="vp-tab-panel"
              role="tabpanel"
              id={`vp-panel-${tab.id}`}
              aria-labelledby={`vp-tab-${tab.id}`}
              data-panel={tab.id}
              hidden={i !== 0}
            >
              <h3 class="text-white font-800 text-xl mb-4 leading-tight tracking-tight">
                {tab.title}
              </h3>
              <p class="text-white/60 text-base leading-relaxed">
                {tab.text}
              </p>

              <!-- Grafismo oficial do site original -->
              <div class="vp-tab-art">
                <img
                  src={tab.image}
                  alt={tab.imageAlt}
                  width="242"
                  height="178"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          ))}

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.vp-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.vp-tab-panel');
  const section = document.querySelector<HTMLElement>('[data-vp-section]');
  const tabIds = Array.from(btns).map((btn) => btn.dataset.tab).filter(Boolean);
  let activeId = tabIds[0] ?? '01';

  const setActiveTab = (id: string | undefined) => {
    if (!id || id === activeId) return;
    activeId = id;

    btns.forEach((btn) => {
      btn.setAttribute('aria-selected', String(btn.dataset.tab === id));
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.panel !== id;
    });
  };

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      setActiveTab(btn.dataset.tab);
    });
  });

  if (section && tabIds.length > 1) {
    let ticking = false;

    const syncTabWithScroll = () => {
      ticking = false;

      const rect = section.getBoundingClientRect();
      const triggerY = window.innerHeight * 0.58;

      if (rect.top > triggerY || rect.bottom < triggerY) return;

      const scrollRange = Math.max(rect.height - window.innerHeight, 1);
      const rawProgress = (triggerY - rect.top) / scrollRange;
      const progress = Math.min(Math.max(rawProgress, 0), 0.999);
      const index = Math.min(Math.floor(progress * tabIds.length), tabIds.length - 1);

      setActiveTab(tabIds[index]);
    };

    const requestScrollSync = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(syncTabWithScroll);
    };

    window.addEventListener('scroll', requestScrollSync, { passive: true });
    window.addEventListener('resize', requestScrollSync);
    requestScrollSync();
  }
</script>

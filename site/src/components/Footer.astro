---
const year = new Date().getFullYear();

const links = {
  site: [
    { href: '/#sobre', label: 'Sobre' },
    { href: '/#o-que-fazemos', label: 'O que fazemos' },
    { href: '/eventos/', label: 'Eventos' },
    { href: '/blog/', label: 'Blog' },
  ],
  legal: [
    { href: '/politica-de-privacidade/', label: 'Política de Privacidade' },
    { href: '/termos-de-uso/', label: 'Termos de Uso' },
  ],
  social: [
    {
      href: 'https://www.linkedin.com/company/masterboard',
      label: 'LinkedIn',
      icon: `<svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`,
    },
    {
      href: 'https://www.instagram.com/masterboard',
      label: 'Instagram',
      icon: `<svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
    },
  ],
};
---

<footer class="site-footer" role="contentinfo">
  <div class="container py-16 md:py-20">

    <!-- Top row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" aria-label="Masterboard" class="brand-lockup mb-4">
          <picture>
            <source srcset="/brand/masterboard-logo-light.webp" type="image/webp" />
            <img
              src="/brand/masterboard-logo-light.png"
              alt="Masterboard"
              class="brand-logo brand-logo--footer"
              width="2001"
              height="176"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          Onde a experiência transforma, o ecossistema eleva.
        </p>
        <div class="flex gap-3 mt-5">
          {links.social.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 border border-mb-border flex items-center justify-center text-white/50 hover:text-mb-yellow hover:border-mb-yellow/30 transition-colors"
              aria-label={label}
            >
              <span class="w-4 h-4" set:html={icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="text-xs font-700 tracking-widest text-white/40 uppercase mb-4">Site</p>
        <ul class="flex flex-col gap-2">
          {links.site.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-white/60 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <p class="text-sm font-600 text-white/80 mb-3">Tava faltando você nessa conversa.</p>
        <a
          href="/aplicacao/"
          class="btn-primary text-sm"
          aria-label="Abrir candidatura"
        >
          Faça parte do club
        </a>
        <p class="text-xs text-white/30 mt-3">
          Acesso por curadoria.
        </p>
      </div>
    </div>

    <!-- Divider -->
    <div class="divider mb-8"></div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-xs text-white/35">
      <p>
        © {year} Masterboard. Todos os direitos reservados.
      </p>
      <div class="flex flex-wrap gap-4">
        {links.legal.map(({ href, label }) => (
          <a href={href} class="hover:text-white/60 transition-colors">{label}</a>
        ))}
      </div>
    </div>

  </div>
</footer>

---
/**
 * Seção de comunidade.
 * O endpoint público de usuários do Bubble não expõe nomes/fotos de membros.
 * Por isso, a seção usa a coleção pública `empresa`, que traz empresas reais
 * vinculadas à comunidade sem criar associações pessoais ambíguas.
 */

import type { MemberCompany } from '../types/domain';

interface Props {
  companies?: MemberCompany[];
  companyCount?: number;
  memberCount?: number;
}

const { companies = [], companyCount, memberCount } = Astro.props;

const visibleCompanies = companies
  .filter((company) => company.name)
  .slice(0, 18);

const displayCompanyCount = companyCount ?? Math.max(companies.length, visibleCompanies.length);
const displayMemberCount = memberCount ?? 0;
const moreCompaniesLabel = `E MAIS ${displayCompanyCount.toLocaleString('pt-BR')} EMPRESAS MAPEADAS`;

const getCompanyInitials = (name: string) => {
  const ignored = new Set(['de', 'da', 'do', 'das', 'dos', 'e']);
  const parts = name
    .replace(/[^\p{L}\p{N}\s]/gu, ' ')
    .split(/\s+/)
    .map((part) => part.trim())
    .filter((part) => part && !ignored.has(part.toLowerCase()));

  return parts
    .slice(0, 2)
    .map((part) => part.charAt(0).toUpperCase())
    .join('') || 'MB';
};

const compactRevenue = (revenue?: string) =>
  revenue
    ?.replace(/ao ano/gi, '')
    .replace(/De\s+/gi, '')
    .replace(/\s+/g, ' ')
    .trim();

const segments = Array.from(
  new Set(
    visibleCompanies
      .map((company) => company.sector)
      .filter((sector): sector is string => Boolean(sector)),
  ),
).slice(0, 10);
---

<section
  id="membros"
  class="section-py bg-mb-black relative overflow-hidden"
  aria-labelledby="members-heading"
>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="brand-grid-mark" aria-hidden="true" style="opacity:0.35; right: 2%; bottom: 5%;"></div>

  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-8 lg:gap-14 mb-12 md:mb-14">
      <div>
        <p class="eyebrow mb-4" data-animate>A comunidade</p>
        <h2
          id="members-heading"
          class="section-title text-balance"
          data-animate
          data-animate-delay="100"
        >
          <span class="text-mb-yellow">{displayCompanyCount.toLocaleString('pt-BR')}+</span> empresas
          conectadas pela sala certa.
        </h2>
      </div>

      <div class="community-summary" data-animate data-animate-delay="150">
        <p class="text-white/56 leading-relaxed">
          Os nomes e fotos pessoais dos membros não são expostos pelo endpoint público.
          Por isso, mostramos empresas reais cadastradas na comunidade, com dados públicos de porte,
          cidade e momento de negócio.
        </p>
        {displayMemberCount > 0 && (
          <p class="community-summary__count">
            {displayMemberCount.toLocaleString('pt-BR')}+ líderes cadastrados no ecossistema.
          </p>
        )}
      </div>
    </div>

    <div class="members-grid-shell" data-animate data-animate-delay="200">
      {visibleCompanies.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
          {visibleCompanies.map((company, i) => (
            <article
              class="member-company-card"
              data-animate
              data-animate-delay={String((i % 6) * 60)}
              aria-label={`${company.name}${company.city ? `, ${company.city}` : ''}`}
            >
              <div class="member-company-card__mark" aria-hidden="true">
                {getCompanyInitials(company.name)}
              </div>
              <div class="member-company-card__body">
                <div>
                  <p class="member-company-card__eyebrow">
                    {company.city ?? company.sector ?? 'Empresa membro'}
                  </p>
                  <h3 class="member-company-card__name">{company.name}</h3>
                </div>

                <div class="member-company-card__meta">
                  {company.size && <span>{company.size}</span>}
                  {compactRevenue(company.revenue) && <span>{compactRevenue(company.revenue)}</span>}
                  {company.sector && <span>{company.sector}</span>}
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="member-company-empty">
          <span>Empresas da comunidade em sincronização.</span>
        </div>
      )}

      <div class="members-grid-fade" aria-hidden="true"></div>
      <div class="members-more">
        <a href="#eventos" class="members-more__button">
          {moreCompaniesLabel}
        </a>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-mb-border" data-animate>
      <p class="text-xs text-white/30 uppercase tracking-widest mb-4">Segmentos representados</p>
      <div class="flex flex-wrap gap-2">
        {(segments.length > 0 ? segments : ['Tecnologia', 'Gastronomia', 'Governança', 'Marketing', 'Energia']).map((segment) => (
          <span class="text-xs px-3 py-1 rounded-full bg-white/5 border border-mb-border text-white/45">
            {segment}
          </span>
        ))}
        <span class="text-xs px-3 py-1 rounded-full bg-mb-yellow/10 border border-mb-yellow/20 text-mb-yellow/75">
          e mais
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .community-summary {
    align-self: end;
    max-width: 38rem;
  }

  .community-summary__count {
    margin-top: 1rem;
    color: rgba(251,190,10,0.78);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .members-grid-shell {
    position: relative;
  }

  .member-company-card {
    min-height: 11.5rem;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1rem;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.25rem;
    padding: 1.1rem;
    background:
      linear-gradient(135deg, rgba(251,190,10,0.075), rgba(255,255,255,0.035) 45%, rgba(255,255,255,0.018)),
      rgba(255,255,255,0.035);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.055);
    transition: border-color 0.22s ease, background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .member-company-card:hover {
    border-color: rgba(251,190,10,0.24);
    background:
      linear-gradient(135deg, rgba(251,190,10,0.11), rgba(255,255,255,0.045) 45%, rgba(255,255,255,0.02)),
      rgba(255,255,255,0.045);
    transform: translateY(-3px);
    box-shadow: 0 18px 44px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.07);
  }

  .member-company-card__mark {
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(251,190,10,0.24);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 32% 24%, rgba(251,190,10,0.22), transparent 40%),
      rgba(0,0,0,0.34);
    color: rgba(251,190,10,0.88);
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .member-company-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .member-company-card__eyebrow {
    margin: 0 0 0.35rem;
    color: rgba(251,190,10,0.68);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .member-company-card__name {
    margin: 0;
    color: var(--mb-white);
    font-size: clamp(1.05rem, 1.6vw, 1.28rem);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  .member-company-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .member-company-card__meta span {
    max-width: 100%;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    padding: 0.3rem 0.52rem;
    background: rgba(0,0,0,0.22);
    color: rgba(255,255,255,0.56);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .member-company-empty {
    min-height: 16rem;
    border: 1px dashed rgba(255,255,255,0.12);
    border-radius: 1.25rem;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.015)),
      rgba(255,255,255,0.025);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.22);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .members-grid-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: min(10rem, 40%);
    pointer-events: none;
    background: linear-gradient(
      to top,
      var(--mb-black) 0%,
      rgba(5,5,5,0.9) 34%,
      rgba(5,5,5,0.44) 72%,
      rgba(5,5,5,0) 100%
    );
  }

  .members-more {
    position: absolute;
    left: 50%;
    bottom: clamp(0.6rem, 2vw, 1.15rem);
    transform: translateX(-50%);
    width: min(100%, 38rem);
    padding-inline: 1rem;
    display: flex;
    justify-content: center;
    z-index: 3;
  }

  .members-more__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 34rem);
    min-height: 3.4rem;
    padding: 0.95rem 1.5rem;
    border-radius: 1rem;
    background: var(--mb-yellow);
    color: var(--mb-black);
    font-size: clamp(0.86rem, 1.8vw, 1.25rem);
    font-weight: 900;
    letter-spacing: 0.035em;
    text-align: center;
    text-transform: uppercase;
    box-shadow: 0 18px 44px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .members-more__button:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
  }

  @media (max-width: 640px) {
    .member-company-card {
      grid-template-columns: 3.35rem minmax(0, 1fr);
    }

    .member-company-card__mark {
      width: 3.35rem;
      height: 3.35rem;
      border-radius: 0.85rem;
    }
  }
</style>

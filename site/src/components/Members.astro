---
/**
 * Seção de membros.
 * Formato principal esperado: foto do membro, inicial do primeiro nome,
 * sobrenome e empresa. Se o Bubble público não expuser perfis pessoais
 * completos, a seção cai para empresas reais da comunidade sem inventar pessoas.
 */

import type { Member, MemberCompany, Speaker } from '../types/domain';
import { getResponsiveImageAttrs } from '../lib/responsive-image';
import {
  MEMBER_COMPANY_VISIBLE_COUNT,
  MEMBER_PROFILE_VISIBLE_COUNT,
  MEMBER_VISIBLE_ROWS,
  pickMembersWithUniqueCompanies,
  sortCompaniesByPrestige,
} from '../lib/member-company-score';
import {
  buildSpeakerPhotoLookup,
  resolveMemberPhoto,
} from '../lib/member-photo';

interface Props {
  members?: Member[];
  companies?: MemberCompany[];
  speakers?: Speaker[];
  companyCount?: number;
  memberCount?: number;
}

const { members = [], companies = [], speakers = [], companyCount, memberCount } = Astro.props;

const speakerPhotoLookup = buildSpeakerPhotoLookup(speakers);

const getNameParts = (name: string) =>
  name
    .replace(/\./g, ' ')
    .split(/\s+/)
    .map((part) => part.trim())
    .filter(Boolean);

const getMemberDisplayName = (name: string) => {
  const parts = getNameParts(name);
  const firstName = parts[0] ?? '';
  const surname = parts.length > 1 ? parts[parts.length - 1] : firstName;
  const initial = firstName.charAt(0).toUpperCase();

  return initial && surname ? `${initial}. ${surname}` : name;
};

const getMemberRole = (member: Member) => member.role ?? member.roleLabel;

const getMemberPhoto = (member: Member) =>
  resolveMemberPhoto(
    {
      name: member.name,
      sourceId: member.sourceId,
      photo: member.photo,
      companyLogo: member.companyLogo,
      linkedin: member.linkedin,
    },
    speakerPhotoLookup,
  );

const eligibleMembers = members
  .map((member) => ({
    ...member,
    photo: getMemberPhoto(member),
  }))
  .filter(
    (member) =>
      member.name &&
      member.photo &&
      member.company &&
      getMemberRole(member) &&
      getNameParts(member.name).length >= 2,
  );

const visibleMembers = pickMembersWithUniqueCompanies(
  eligibleMembers,
  MEMBER_PROFILE_VISIBLE_COUNT,
);

// Membros destacados — sempre exibidos no topo da grade, independente dos dados do Supabase
const featuredMembers: Member[] = [
  { id: 'feat-1',  sourceId: 'feat-1',  source: 'static', name: 'Leonardo Nogueira', role: 'CEO',                     company: 'Barigui' },
  { id: 'feat-2',  sourceId: 'feat-2',  source: 'static', name: 'Fabiano Szpyra',    role: 'Diretoria',               company: 'Festval',           photo: '/members/fabiano-szpyra.jpg' },
  { id: 'feat-3',  sourceId: 'feat-3',  source: 'static', name: 'Wagner Villaverde', role: 'CEO',                     company: 'Outback Sul' },
  { id: 'feat-4',  sourceId: 'feat-4',  source: 'static', name: 'Marcos Koch',       role: 'Diretor',                 company: 'Ford' },
  { id: 'feat-5',  sourceId: 'feat-5',  source: 'static', name: 'Marcelo Matuella',  role: 'Fundador',                company: 'Maltta' },
  { id: 'feat-6',  sourceId: 'feat-6',  source: 'static', name: 'Rafa Magosso',      role: 'Proprietário',            company: 'Hard Rock Curitiba', photo: '/members/rafael-magosso.jpg' },
  { id: 'feat-7',  sourceId: 'feat-7',  source: 'static', name: 'Marilucia Pertile', role: 'Investidora & Conselheira', company: 'Independente' },
  { id: 'feat-8',  sourceId: 'feat-8',  source: 'static', name: 'Jefferson Souza',   role: 'CEO',                     company: 'Só Carrão' },
  { id: 'feat-9',  sourceId: 'feat-9',  source: 'static', name: 'Alex Pinheiro',     role: 'Diretor',                 company: 'BTG Pactual' },
  { id: 'feat-10', sourceId: 'feat-10', source: 'static', name: 'Edu e Sandrinho',   role: 'Sócios & Co-fundadores',  company: 'Market4u',           photo: '/members/eduardo-cordova.png' },
];

// object-position customizado para fotos que não são retratos verticais centrados
const memberPhotoPosition: Record<string, string> = {
  'feat-6': 'left top',
};

const featuredNameKeys = new Set(featuredMembers.map((m) => m.name.toLowerCase().trim()));
const filteredSupabaseMembers = visibleMembers.filter(
  (m) => !featuredNameKeys.has(m.name.toLowerCase().trim()),
);
const displayMembers = [...featuredMembers, ...filteredSupabaseMembers].slice(0, MEMBER_PROFILE_VISIBLE_COUNT);

const visibleCompanies = sortCompaniesByPrestige(
  companies.filter((company) => company.name),
).slice(0, MEMBER_COMPANY_VISIBLE_COUNT);

const hasMemberProfiles = displayMembers.length > 0;
const displayMemberCount = memberCount ?? Math.max(members.length, displayMembers.length);
const displayCompanyCount = companyCount ?? Math.max(companies.length, visibleCompanies.length);
const moreLabel = hasMemberProfiles
  ? `E MAIS ${displayMemberCount.toLocaleString('pt-BR')} MEMBROS`
  : `E MAIS ${displayCompanyCount.toLocaleString('pt-BR')} EMPRESAS MAPEADAS`;

const getCompanyInitials = (name: string) => {
  const ignored = new Set(['de', 'da', 'do', 'das', 'dos', 'e']);
  const parts = name
    .replace(/[^\p{L}\p{N}\s]/gu, ' ')
    .split(/\s+/)
    .map((part) => part.trim())
    .filter((part) => part && !ignored.has(part.toLowerCase()));

  return parts
    .slice(0, 2)
    .map((part) => part.charAt(0).toUpperCase())
    .join('') || 'MB';
};

const compactRevenue = (revenue?: string) =>
  revenue
    ?.replace(/ao ano/gi, '')
    .replace(/De\s+/gi, '')
    .replace(/\s+/g, ' ')
    .trim();

const getMemberImageAttrs = (src: string) => getResponsiveImageAttrs(src, {
  widths: [160, 320, 480],
  sizes: '(min-width: 1024px) 16vw, (min-width: 640px) 33vw, 50vw',
  quality: 72,
});
---

<section
  id="membros"
  class="section-py section-ambient relative overflow-hidden"
  aria-labelledby="members-heading"
>
  <div class="mb-glow-orb mb-glow-orb--bottom-left" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="brand-grid-mark" aria-hidden="true" style="opacity:0.35; right: 2%; bottom: 5%;"></div>

  <div class="container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-8 lg:gap-14 mb-12 md:mb-14">
      <div>
        <p class="eyebrow mb-4" data-animate>A comunidade</p>
        <h2
          id="members-heading"
          class="section-title text-balance"
          data-animate
          data-animate-delay="100"
        >
          <span class="text-mb-yellow">{displayMemberCount.toLocaleString('pt-BR')}+</span> líderes
          conectados pela sala certa.
        </h2>
      </div>

      <div class="community-summary" data-animate data-animate-delay="150">
        <p class="text-white/56 leading-relaxed">
          {hasMemberProfiles
            ? 'Perfis selecionados da comunidade, com foto do membro, sobrenome e empresa.'
            : 'A API pública ainda não expõe fotos e nomes completos dos membros. Enquanto isso, mostramos empresas reais cadastradas no ecossistema.'}
        </p>
      </div>
    </div>

    <div
      class="members-grid-shell"
      data-animate
      data-animate-delay="200"
      style={`--members-visible-rows: ${MEMBER_VISIBLE_ROWS}`}
    >
      {hasMemberProfiles ? (
        <div class="members-profile-grid grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 md:gap-4">
          {displayMembers.map((member, i) => (
            <article
              class="member-profile-card"
              data-animate
              data-animate-delay={String((i % 6) * 60)}
              aria-label={`${getMemberDisplayName(member.name)}, ${getMemberRole(member)}, ${member.company}`}
            >
              {member.photo ? (
                <img
                  {...getMemberImageAttrs(member.photo)}
                  alt={member.name}
                  loading="lazy"
                  fetchpriority="low"
                  decoding="async"
                  width="320"
                  height="320"
                  class="member-profile-card__photo"
                  style={memberPhotoPosition[member.id] ? `object-position: ${memberPhotoPosition[member.id]}` : undefined}
                />
              ) : (
                <div class="member-profile-card__initials" aria-hidden="true">
                  {member.name.charAt(0).toUpperCase()}
                </div>
              )}
              <div class="member-profile-card__info">
                <p class="member-profile-card__name">{getMemberDisplayName(member.name)}</p>
                <p class="member-profile-card__role">{getMemberRole(member)}</p>
                <p class="member-profile-card__company">{member.company}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="members-company-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
          {visibleCompanies.map((company, i) => (
            <article
              class="member-company-card"
              data-animate
              data-animate-delay={String((i % 6) * 60)}
              aria-label={`${company.name}${company.city ? `, ${company.city}` : ''}`}
            >
              <div class="member-company-card__mark" aria-hidden="true">
                {getCompanyInitials(company.name)}
              </div>
              <div class="member-company-card__body">
                <div>
                  <p class="member-company-card__eyebrow">
                    {company.city ?? company.sector ?? 'Empresa membro'}
                  </p>
                  <h3 class="member-company-card__name">{company.name}</h3>
                </div>

                <div class="member-company-card__meta">
                  {company.size && <span>{company.size}</span>}
                  {compactRevenue(company.revenue) && <span>{compactRevenue(company.revenue)}</span>}
                  {company.sector && <span>{company.sector}</span>}
                </div>
              </div>
            </article>
          ))}
        </div>
      )}

      <div class="members-grid-fade" aria-hidden="true"></div>
      <div class="members-more">
        <a href="#eventos" class="members-more__button">
          {moreLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .community-summary {
    align-self: end;
    max-width: 38rem;
  }

  .members-grid-shell {
    position: relative;
    container-type: inline-size;
  }

  .members-profile-grid,
  .members-company-grid {
    --members-gap: 0.75rem;
    --members-columns: 2;
    overflow: hidden;
    max-height: calc(
      ((100cqi - ((var(--members-columns) - 1) * var(--members-gap))) / var(--members-columns))
        * var(--members-visible-rows, 2.5)
      + (var(--members-gap) * (var(--members-visible-rows, 2.5) - 0.5))
    );
  }

  @media (min-width: 640px) {
    .members-profile-grid,
    .members-company-grid {
      --members-gap: 1rem;
    }

    .members-profile-grid {
      --members-columns: 3;
    }

    .members-company-grid {
      --members-columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .members-profile-grid {
      --members-columns: 6;
    }

    .members-company-grid {
      --members-columns: 3;
    }
  }

  .member-profile-card {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.25rem;
    background: rgba(255,255,255,0.04);
    transition: border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .member-profile-card:hover {
    border-color: rgba(251,190,10,0.25);
    transform: translateY(-3px);
    box-shadow: 0 18px 44px rgba(0,0,0,0.32);
  }

  .member-profile-card__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: contrast(1.04);
    transition: transform 0.3s ease;
  }

  .member-profile-card__initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(2.5rem, 6cqi, 4rem);
    font-weight: 900;
    color: rgba(251, 190, 10, 0.30);
    letter-spacing: -0.04em;
  }

  .member-profile-card:hover .member-profile-card__photo {
    transform: scale(1.045);
  }

  .member-profile-card__info {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 3rem 0.85rem 0.85rem;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.96) 0%,
      rgba(0,0,0,0.76) 48%,
      rgba(0,0,0,0) 100%
    );
  }

  .member-profile-card__name {
    margin: 0;
    color: var(--mb-white);
    font-size: clamp(0.98rem, 1.35vw, 1.12rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.95);
  }

  .member-profile-card__company {
    margin: 0.2rem 0 0;
    color: rgba(251,190,10,0.82);
    font-size: clamp(0.68rem, 0.95vw, 0.78rem);
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .member-profile-card__role {
    margin: 0.35rem 0 0;
    color: rgba(255,255,255,0.76);
    font-size: clamp(0.66rem, 0.9vw, 0.76rem);
    font-weight: 700;
    line-height: 1.18;
  }

  .member-company-card {
    min-height: 11.5rem;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1rem;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.25rem;
    padding: 1.1rem;
    background:
      linear-gradient(135deg, rgba(251,190,10,0.075), rgba(255,255,255,0.035) 45%, rgba(255,255,255,0.018)),
      rgba(255,255,255,0.035);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.055);
    transition: border-color 0.22s ease, background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .member-company-card:hover {
    border-color: rgba(251,190,10,0.24);
    background:
      linear-gradient(135deg, rgba(251,190,10,0.11), rgba(255,255,255,0.045) 45%, rgba(255,255,255,0.02)),
      rgba(255,255,255,0.045);
    transform: translateY(-3px);
    box-shadow: 0 18px 44px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.07);
  }

  .member-company-card__mark {
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(251,190,10,0.24);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 32% 24%, rgba(251,190,10,0.22), transparent 40%),
      rgba(0,0,0,0.34);
    color: rgba(251,190,10,0.88);
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .member-company-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .member-company-card__eyebrow {
    margin: 0 0 0.35rem;
    color: rgba(251,190,10,0.68);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .member-company-card__name {
    margin: 0;
    color: var(--mb-white);
    font-size: clamp(1.05rem, 1.6vw, 1.28rem);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  .member-company-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .member-company-card__meta span {
    max-width: 100%;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    padding: 0.3rem 0.52rem;
    background: rgba(0,0,0,0.22);
    color: rgba(255,255,255,0.56);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .members-grid-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: min(11rem, 46%);
    pointer-events: none;
    background: linear-gradient(
      to top,
      var(--mb-black) 0%,
      rgba(5,5,5,0.9) 34%,
      rgba(5,5,5,0.44) 72%,
      rgba(5,5,5,0) 100%
    );
  }

  .members-more {
    position: absolute;
    left: 50%;
    bottom: clamp(0.6rem, 2vw, 1.15rem);
    transform: translateX(-50%);
    width: min(100%, 38rem);
    padding-inline: 1rem;
    display: flex;
    justify-content: center;
    z-index: 3;
  }

  .members-more__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 34rem);
    min-height: 3.4rem;
    padding: 0.95rem 1.5rem;
    border-radius: 1rem;
    background: var(--mb-yellow);
    color: var(--mb-black);
    font-size: clamp(0.86rem, 1.8vw, 1.25rem);
    font-weight: 900;
    letter-spacing: 0.035em;
    text-align: center;
    text-transform: uppercase;
    box-shadow: 0 18px 44px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .members-more__button:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
  }

  @media (max-width: 640px) {
    .member-company-card {
      grid-template-columns: 3.35rem minmax(0, 1fr);
    }

    .member-company-card__mark {
      width: 3.35rem;
      height: 3.35rem;
      border-radius: 0.85rem;
    }
  }
</style>

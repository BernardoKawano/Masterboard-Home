---
import type { Speaker } from '../types/domain';
import { getResponsiveImageAttrs } from '../lib/responsive-image';
import { displaySpeakerRole, speakerCompanyFieldLabel } from '../lib/speaker-display';

interface Props {
  speakers: Speaker[];
}

const { speakers } = Astro.props;

const getSpeakerCompanies = (speaker: Speaker): string[] => {
  if (speaker.companies?.length) return speaker.companies;
  if (speaker.company) return [speaker.company];
  return [];
};

const featuredCompanySignals = [
  'viasoft', 'rp trader', 'fight music show', 'driva', 'vpx',
  'coca-cola', 'auda', '+1 cafe', 'ivs franquias',
];

const normalize = (value: string) =>
  value.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();

const getSpeakerScore = (speaker: Speaker) => {
  const role = normalize([speaker.roleLabel, speaker.role, speaker.company].filter(Boolean).join(' '));
  let score = 0;
  if (featuredCompanySignals.some((s) => role.includes(s))) score += 120;
  if (/\b(ceo|cfo|cto|coo|cmo|cco|cso|cro)\b/.test(role)) score += 110;
  if (/\b(presidente|vice-presidente|vp)\b/.test(role)) score += 72;
  if (/\b(founder|fundador|fundadora|co-founder|socio|socia|owner)\b/.test(role)) score += 62;
  if (/\b(diretor|diretora|executivo|executiva)\b/.test(role)) score += 36;
  if (speaker.companyLogo) score += 12;
  if (speaker.photo) score += 8;
  return score;
};

// Ajustes de enquadramento por speaker (chave = nome normalizado)
const photoPositionOverrides: Record<string, string> = {
  'rafa mendes': 'left center',
};

const getPhotoPosition = (speaker: Speaker): string | undefined =>
  speaker.photoPosition ?? photoPositionOverrides[normalize(speaker.name)];

const seenNames = new Set<string>();
const visibleSpeakers = [...speakers]
  .sort((a, b) => getSpeakerScore(b) - getSpeakerScore(a))
  .filter((s) => {
    const key = normalize(s.name);
    if (seenNames.has(key)) return false;
    seenNames.add(key);
    return true;
  });

const getSpeakerImageAttrs = (src: string) => getResponsiveImageAttrs(src, {
  widths: [240, 360, 540, 720],
  sizes: '(min-width: 1024px) 30vw, 82vw',
  quality: 74,
});

const total = visibleSpeakers.length;
const initialSpeaker = visibleSpeakers[0];
const initialCompanies = initialSpeaker ? getSpeakerCompanies(initialSpeaker) : [];
---

{total > 0 && (
<section
  id="speakers"
  class="section-py section-ambient relative overflow-hidden"
  aria-labelledby="speakers-heading"
>
  <div class="mb-glow-orb mb-glow-orb--top-right" aria-hidden="true"></div>
  <div class="mb-glow-orb mb-glow-orb--bottom-left" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="container relative z-10">

    <!-- ── Cabeçalho ───────────────────────────────────────── -->
    <div class="max-w-2xl mb-10 md:mb-12">
      <p class="eyebrow mb-4" data-animate>// Speakers</p>
      <h2
        id="speakers-heading"
        class="section-title text-white text-balance"
        data-animate data-animate-delay="100"
      >
        Aprenda com quem<br />
        <span class="text-mb-yellow">está no jogo</span>
      </h2>
    </div>

    <!-- ── Stage ───────────────────────────────────────────── -->
    <div
      class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-10 lg:gap-14 items-center"
      data-animate data-animate-delay="200"
    >

      <!-- Coluna esquerda: info do speaker ativo -->
      <div class="spk-info order-2 lg:order-1">
        <p class="speaker-context-copy mb-8">
          Aqui você aprende com
          <span class="speaker-highlight">empresários que estão no jogo</span>, liderando
          empresas e compartilhando os bastidores reais do crescimento.
        </p>

        <!-- Empresa(s) -->
        <div id="spk-company-wrap" class="spk-company-wrap">
          <p id="spk-company-label" class="spk-field-label">
            {speakerCompanyFieldLabel(initialCompanies.length)}
          </p>
          <div id="spk-companies" class="spk-companies-list">
            {initialCompanies.map((company) => (
              <span class="spk-company">{company}</span>
            ))}
          </div>
        </div>

        <!-- Speaker -->
        <div class="spk-field-block">
          <p class="spk-field-label">Speaker</p>
          <h3 id="spk-name" class="spk-name">
            {visibleSpeakers[0]?.name}
          </h3>
        </div>

        <!-- Cargo -->
        <div id="spk-role-wrap" class="spk-role-wrap spk-field-block">
          <p class="spk-field-label">Cargo</p>
          <div class="spk-role-line">
            <span class="spk-role-dot"></span>
            <p id="spk-role" class="spk-role">
              {displaySpeakerRole(initialSpeaker?.role, initialSpeaker?.roleLabel)}
            </p>
          </div>
        </div>

        <!-- Apresenta -->
        <div class="spk-field-block spk-presents-block">
          <p class="spk-field-label">Apresenta</p>
          <p id="spk-bio" class="spk-bio">
            {visibleSpeakers[0]?.bio ?? ''}
          </p>
        </div>

        <!-- Setas -->
        <div class="flex items-center gap-3 mt-8">
          <button class="spk-arrow spk-arrow-prev" type="button" aria-label="Speaker anterior">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
          </button>
          <button class="spk-arrow spk-arrow-next" type="button" aria-label="Próximo speaker">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </div>

      </div>

      <!-- Coluna direita: carrossel de fotos -->
      <div class="spk-carousel order-1 lg:order-2">
        <div class="spk-track" id="spk-track">
          {visibleSpeakers.map((speaker, i) => (
            <button
              class="spk-slide"
              data-index={String(i)}
              data-active={i === 0 ? 'true' : 'false'}
              type="button"
              aria-label={`Ver ${speaker.name} — ${speaker.roleLabel}`}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {speaker.photo ? (
                <img
                  {...getSpeakerImageAttrs(speaker.photo)}
                  alt={speaker.name}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : 'low'}
                  decoding="async"
                  width="360"
                  height="480"
                  style={getPhotoPosition(speaker) ? `object-position: ${getPhotoPosition(speaker)}` : undefined}
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
              ) : null}
              <div
                class="spk-slide-fallback"
                style={speaker.photo ? 'display:none' : 'display:flex'}
                aria-hidden="true"
              >
                {speaker.name.charAt(0).toUpperCase()}
              </div>
              <!-- Faixa superior: empresa -->
              <div class="spk-card-top" data-has-company={speaker.company ? 'true' : 'false'} aria-hidden="true">
                <span class="spk-card-company">{speaker.company ?? ''}</span>
              </div>
              <!-- Faixa inferior: nome + cargo -->
              <div class="spk-card-bottom" aria-hidden="true">
                <span class="spk-card-name">{speaker.name}</span>
                <span class="spk-card-role">{displaySpeakerRole(speaker.role, speaker.roleLabel)}</span>
              </div>
            </button>
          ))}
        </div>
      </div>

    </div>

    <!-- ── Dots ────────────────────────────────────────────── -->
    <div
      class="flex justify-center lg:justify-start items-center gap-2 mt-10"
      role="tablist"
      aria-label="Navegar entre speakers"
    >
      {visibleSpeakers.map((_, i) => (
        <button
          class="spk-dot"
          data-dot={String(i)}
          data-active={i === 0 ? 'true' : 'false'}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Speaker ${i + 1} de ${total}`}
        ></button>
      ))}
    </div>

  </div>
</section>
)}

{total === 0 && (
<section id="speakers" class="section-py bg-mb-black">
  <div class="container">
    <p class="text-white/40 text-center py-10 text-sm tracking-widest uppercase">Speakers em breve.</p>
  </div>
</section>
)}

<style>
  .speaker-context-copy {
    max-width: 30rem;
    color: rgba(255,255,255,0.55);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .speaker-highlight {
    display: inline;
    padding: 0.04em 0.12em 0.08em;
    background: var(--mb-yellow);
    color: var(--mb-black);
    font-weight: 800;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
</style>

<!-- Dados passados para o script -->
<div
  id="spk-data"
  hidden
  data-json={JSON.stringify(visibleSpeakers.map(s => {
    const companies = getSpeakerCompanies(s);
    return {
      name: s.name,
      companies,
      companyLabel: speakerCompanyFieldLabel(companies.length),
      role: displaySpeakerRole(s.role, s.roleLabel),
      bio: s.bio ?? '',
    };
  }))}
></div>

<script is:inline>
(function () {
  var CLONES  = 3; // clones em cada ponta para efeito cilíndrico

  var trackEl = document.getElementById('spk-track');
  if (!trackEl) return;

  // Captura slides reais ANTES de clonar
  var realSlides = Array.from(trackEl.querySelectorAll('.spk-slide'));
  var total      = realSlides.length;
  if (total === 0) return;

  // Prepend: clones dos últimos CLONES slides (em ordem: total-3, total-2, total-1)
  // Inserindo de trás pra frente no insertBefore para manter a ordem correta
  for (var i = 0; i < CLONES; i++) {
    var cp = realSlides[total - 1 - i].cloneNode(true);
    cp.dataset.active = 'false';
    cp.removeAttribute('aria-pressed');
    cp.setAttribute('aria-hidden', 'true');
    cp.setAttribute('tabindex', '-1');
    trackEl.insertBefore(cp, trackEl.firstChild);
  }
  // Append: clones dos primeiros CLONES slides
  for (var j = 0; j < CLONES; j++) {
    var ca = realSlides[j].cloneNode(true);
    ca.dataset.active = 'false';
    ca.removeAttribute('aria-pressed');
    ca.setAttribute('aria-hidden', 'true');
    ca.setAttribute('tabindex', '-1');
    trackEl.appendChild(ca);
  }

  // allItems: [clone(N-3), clone(N-2), clone(N-1), real(0)…real(N-1), clone(0), clone(1), clone(2)]
  var allItems = Array.from(trackEl.children);

  var dots        = Array.from(document.querySelectorAll('.spk-dot'));
  var nameEl      = document.getElementById('spk-name');
  var roleEl      = document.getElementById('spk-role');
  var bioEl       = document.getElementById('spk-bio');
  var companyLabelEl = document.getElementById('spk-company-label');
  var companiesEl    = document.getElementById('spk-companies');
  var companyWrap = document.getElementById('spk-company-wrap');
  var dataEl      = document.getElementById('spk-data');
  var prevBtn     = document.querySelector('.spk-arrow-prev');
  var nextBtn     = document.querySelector('.spk-arrow-next');
  var autoplayMs  = 3500;
  var autoplayId  = null;

  var speakersData = [];
  try { speakersData = dataEl ? JSON.parse(dataEl.dataset.json || '[]') : []; } catch (_) {}

  var vCurrent = CLONES;  // índice virtual em allItems
  var vActive  = CLONES;  // qual allItem está visualmente ativo
  var busy     = false;   // bloqueia input durante transição+jump

  // ── Posiciona a track ────────────────────────────────────
  function applyTransform(vi, instant) {
    var slideW = allItems[0].offsetWidth;
    var gapPx  = parseFloat(getComputedStyle(trackEl).columnGap) || 14;
    var offset = vi * (slideW + gapPx);
    if (instant) {
      var prev = trackEl.style.transition;
      trackEl.style.transition = 'none';
      trackEl.style.transform  = 'translateX(-' + offset + 'px)';
      trackEl.getBoundingClientRect();
      trackEl.style.transition = prev;
    } else {
      trackEl.style.transform = 'translateX(-' + offset + 'px)';
    }
  }

  // ── Destaca visualmente o item no índice virtual vi ─────
  function setVisualActive(vi) {
    allItems[vActive].dataset.active = 'false';
    allItems[vi].dataset.active = 'true';
    vActive = vi;
  }

  // ── Sincroniza dots e aria dos slides reais ──────────────
  function syncReal(realIdx) {
    realSlides.forEach(function (s, i) {
      s.setAttribute('aria-pressed', i === realIdx ? 'true' : 'false');
    });
    dots.forEach(function (d, i) {
      d.dataset.active      = i === realIdx ? 'true' : 'false';
      d.setAttribute('aria-selected', i === realIdx ? 'true' : 'false');
    });
  }

  // ── Atualiza painel de texto com fade ────────────────────
  function updateInfo(realIdx) {
    var data = speakersData[realIdx];
    if (!data) return;
    [nameEl, roleEl, bioEl, companyWrap].forEach(function (el) { if (el) el.classList.add('spk-fade'); });
    setTimeout(function () {
      if (nameEl)    nameEl.textContent    = data.name;
      if (roleEl)    roleEl.textContent    = data.role;
      if (bioEl)     bioEl.textContent     = data.bio;
      if (companyLabelEl) companyLabelEl.textContent = data.companyLabel || 'Empresa';
      if (companiesEl) {
        companiesEl.innerHTML = (data.companies || []).map(function (c) {
          return '<span class="spk-company">' + String(c).replace(/&/g, '&amp;').replace(/</g, '&lt;') + '</span>';
        }).join('');
      }
      [nameEl, roleEl, bioEl, companyWrap].forEach(function (el) { if (el) el.classList.remove('spk-fade'); });
    }, 180);
  }

  // ── Navega para índice virtual vNext ─────────────────────
  function goTo(vNext) {
    if (busy) return;
    busy = true;

    // Índice real correspondente (funciona para clones também)
    var realNext = ((vNext - CLONES) % total + total) % total;

    setVisualActive(vNext);
    syncReal(realNext);
    updateInfo(realNext);
    vCurrent = vNext;
    applyTransform(vCurrent);

    // Após a transição: jump silencioso se estiver em clone
    setTimeout(function () {
      if (vCurrent < CLONES) {
        vCurrent += total;
        var vReal = vActive + total;
        setVisualActive(vReal);
        applyTransform(vCurrent, true);
      } else if (vCurrent >= CLONES + total) {
        vCurrent -= total;
        var vReal2 = vActive - total;
        setVisualActive(vReal2);
        applyTransform(vCurrent, true);
      }
      busy = false;
    }, 560);
  }

  function stopAutoplay() {
    if (autoplayId) {
      window.clearInterval(autoplayId);
      autoplayId = null;
    }
  }

  function startAutoplay() {
    if (total <= 1 || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    stopAutoplay();
    autoplayId = window.setInterval(function () {
      goTo(vCurrent + 1);
    }, autoplayMs);
  }

  function restartAutoplay() {
    stopAutoplay();
    startAutoplay();
  }

  // ── Inicializa posição ───────────────────────────────────
  applyTransform(vCurrent, true);
  startAutoplay();

  // ── Eventos: cliques em todos os itens (reais + clones) ─
  allItems.forEach(function (item, vi) {
    item.addEventListener('click', function () {
      goTo(vi);
      restartAutoplay();
    });
  });

  dots.forEach(function (dot, i) {
    dot.addEventListener('click', function () {
      goTo(CLONES + i);
      restartAutoplay();
    });
  });

  if (prevBtn) prevBtn.addEventListener('click', function () {
    goTo(vCurrent - 1);
    restartAutoplay();
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    goTo(vCurrent + 1);
    restartAutoplay();
  });

  trackEl.addEventListener('mouseenter', stopAutoplay);
  trackEl.addEventListener('mouseleave', startAutoplay);
  trackEl.addEventListener('focusin', stopAutoplay);
  trackEl.addEventListener('focusout', startAutoplay);
  document.addEventListener('visibilitychange', function () {
    if (document.hidden) stopAutoplay();
    else startAutoplay();
  });

  document.addEventListener('keydown', function (e) {
    var section = document.getElementById('speakers');
    if (!section) return;
    var r = section.getBoundingClientRect();
    if (r.bottom < 0 || r.top > window.innerHeight) return;
    if (e.key === 'ArrowLeft') {
      goTo(vCurrent - 1);
      restartAutoplay();
    }
    if (e.key === 'ArrowRight') {
      goTo(vCurrent + 1);
      restartAutoplay();
    }
  });

  var touchX = 0;
  trackEl.addEventListener('touchstart', function (e) { touchX = e.touches[0].clientX; }, { passive: true });
  trackEl.addEventListener('touchend',   function (e) {
    var diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      goTo(diff > 0 ? vCurrent + 1 : vCurrent - 1);
      restartAutoplay();
    }
  }, { passive: true });

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { applyTransform(vCurrent, true); }, 150);
  });
}());
</script>

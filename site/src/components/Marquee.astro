---
const phrases = [
  'Acesso por aprovação',
  'Salas privadas',
  'Líderes difíceis de acessar',
  'Jantares curados',
  'Matchmaking com contexto',
  'Conversas antes do mercado',
  'Decisões fora do feed',
  'Membros selecionados',
  'Ecossistema fechado',
  'Presença que muda a mesa',
];
---

<div
  class="py-5 bg-mb-yellow overflow-hidden"
  aria-hidden="true"
  role="presentation"
>
  <div class="marquee-wrapper">
    <!-- Duplicado para loop contínuo sem JS -->
    <div class="marquee-track">
      {[...phrases, ...phrases].map((phrase) => (
        <span class="marquee-item text-mb-black">
          <span class="marquee-dot text-mb-black/40" aria-hidden="true">★</span>
          {phrase}
        </span>
      ))}
    </div>
  </div>
</div>

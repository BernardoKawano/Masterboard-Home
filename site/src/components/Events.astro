---
import type { Event } from '../types/domain';
import { getEventUrl } from '../types/domain';
import { eventStatusLabel } from '../lib/event-status';
import { getResponsiveImageAttrs } from '../lib/responsive-image';

interface Props {
  events: Event[];
  /** 'grid' = cards com imagem (home page); 'list' = linha compacta (listagem) */
  layout?: 'grid' | 'list';
  showViewAll?: boolean;
  limit?: number;
}

const {
  events: allEvents,
  layout = 'grid',
  showViewAll = true,
  limit,
} = Astro.props;

const events = limit ? allEvents.slice(0, limit) : allEvents;

const fmtDay   = (iso: string) =>
  new Date(iso).toLocaleDateString('pt-BR', { day: '2-digit', timeZone: 'America/Sao_Paulo' });

const fmtMonth = (iso: string) =>
  new Date(iso)
    .toLocaleDateString('pt-BR', { month: 'short', timeZone: 'America/Sao_Paulo' })
    .replace('.', '');

const fmtFull  = (iso: string) =>
  new Date(iso).toLocaleDateString('pt-BR', {
    day: 'numeric', month: 'long', timeZone: 'America/Sao_Paulo',
  });

const getEventCardImageAttrs = (src: string) => getResponsiveImageAttrs(src, {
  widths: [320, 640, 960],
  sizes: '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw',
  quality: 74,
});
---

<section
  id="eventos"
  class="section-py section-ambient relative overflow-hidden"
  aria-labelledby="events-heading"
>
  <div class="mb-glow-orb mb-glow-orb--top-right" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-mb-border to-transparent"></div>

  <div class="container relative z-10">

    <!-- Cabeçalho -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 md:mb-12">
      <div>
        <p class="eyebrow mb-4" data-animate>Mesas e experiências</p>
        <h2 id="events-heading" class="section-title" data-animate data-animate-delay="100">
          O calendário é público.
          <span class="text-mb-yellow"> A sala não é.</span>
        </h2>
      </div>
      {showViewAll && (
        <a href="/eventos/" class="btn-secondary text-sm self-start md:self-auto"
           data-animate data-animate-delay="150">
          Ver calendário completo
        </a>
      )}
    </div>

    {events.length > 0 ? (

      layout === 'grid' ? (
        /* ── GRID com imagem ── */
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
          {events.map((event, i) => (
            <article
              class="event-image-card group"
              data-animate
              data-animate-delay={String(i * 80)}
            >
              <a href={getEventUrl(event)} class="block h-full" aria-label={`${event.title} — ${fmtFull(event.date)}`}>

                <!-- Imagem de capa -->
                <div class="event-image-card__cover">
                  {event.coverImage ? (
                    <img
                      {...getEventCardImageAttrs(event.coverImage)}
                      alt={event.title}
                      loading="lazy"
                      fetchpriority="low"
                      decoding="async"
                      width="640"
                      height="360"
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      onerror="this.parentElement.classList.add('event-image-card__cover--fallback')"
                    />
                  ) : null}
                  <!-- Fallback visual quando sem imagem -->
                  <div class="event-image-card__cover-fallback" aria-hidden="true">
                    <svg viewBox="0 0 44 38" width="40" height="34" fill="none">
                      <rect x="1"  y="22" width="24" height="10" rx="2.5" fill="#FBBE0A" transform="rotate(-32 13 27)" opacity="0.3"/>
                      <rect x="9"  y="11" width="20" height="8.5" rx="2.5" fill="#FBBE0A" transform="rotate(-32 19 15.25)" opacity="0.3"/>
                      <rect x="19" y="1"  width="16" height="7"   rx="2.5" fill="#FBBE0A" transform="rotate(-32 27 4.5)" opacity="0.3"/>
                    </svg>
                  </div>

                  <!-- Gradiente sobre a imagem -->
                  <div class="event-image-card__gradient" aria-hidden="true"></div>

                  <!-- Badge status (sobre a imagem) -->
                  <div class="event-image-card__badges">
                    <span class={`badge ${event.status === 'upcoming' ? 'badge-upcoming' : 'badge-past'} text-[10px]`}>
                      <span class="w-1.5 h-1.5 rounded-full bg-current" aria-hidden="true"></span>
                      {eventStatusLabel(event.status)}
                    </span>
                    {event.edition && (
                      <span class="badge text-[10px]"
                        style="background:rgba(0,0,0,.55);border-color:rgba(255,255,255,.18);color:rgba(255,255,255,.75);">
                        {event.edition}
                      </span>
                    )}
                  </div>
                </div>

                <!-- Corpo do card -->
                <div class="event-image-card__body">
                  <!-- Data + local -->
                  <div class="flex items-center gap-2 mb-2">
                    <span class="event-image-card__date">
                      {fmtDay(event.date)} {fmtMonth(event.date)}
                    </span>
                    {event.city || event.venue ? (
                      <>
                        <span class="text-white/30 text-xs">·</span>
                        <span class="text-white/45 text-xs truncate">{event.city ?? event.venue}</span>
                      </>
                    ) : null}
                  </div>

                  <!-- Título -->
                  <h3 class="event-image-card__title group-hover:text-mb-yellow transition-colors">
                    {event.title}
                  </h3>

                  <!-- Temas -->
                  {event.topics.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-2" aria-hidden="true">
                      {event.topics.slice(0, 2).map((t) => (
                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/5 border border-mb-border text-white/40">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- CTA -->
                  <div class="event-image-card__cta">
                    <span>Ver evento</span>
                    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (

        /* ── LIST compacta ── */
        <ul class="flex flex-col gap-3" role="list">
          {events.map((event, i) => (
            <li data-animate data-animate-delay={String(i * 70)}>
              <a href={getEventUrl(event)} class="event-card group"
                 aria-label={`${event.title} — ${fmtFull(event.date)} em ${event.venue}`}>

                <div class="event-date-block" aria-hidden="true">
                  <span class="event-date-day">{fmtDay(event.date)}</span>
                  <span class="event-date-month">{fmtMonth(event.date)}</span>
                </div>

                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class={`badge ${event.status === 'upcoming' ? 'badge-upcoming' : 'badge-past'}`}>
                      <span class="w-1.5 h-1.5 rounded-full bg-current" aria-hidden="true"></span>
                      {eventStatusLabel(event.status)}
                    </span>
                    {event.edition && (
                      <span class="badge" style="background:rgba(255,255,255,.04);border-color:var(--mb-border);color:rgba(255,255,255,.45);">
                        {event.edition}
                      </span>
                    )}
                  </div>
                  <h3 class="font-700 text-white text-base md:text-lg truncate group-hover:text-mb-yellow transition-colors">
                    {event.title}
                  </h3>
                  <p class="text-white/45 text-sm mt-0.5">{event.venue}</p>
                </div>

                {event.topics.length > 0 && (
                  <div class="hidden md:flex flex-wrap gap-1.5 max-w-[200px]" aria-hidden="true">
                    {event.topics.slice(0, 2).map((t) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-mb-border text-white/40 whitespace-nowrap">{t}</span>
                    ))}
                  </div>
                )}

                <div class="hidden sm:flex items-center justify-center w-9 h-9 rounded-full border border-mb-border group-hover:border-mb-yellow/40 group-hover:bg-mb-yellow/5 transition-all shrink-0">
                  <svg class="w-4 h-4 text-white/40 group-hover:text-mb-yellow transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                  </svg>
                </div>
              </a>
            </li>
          ))}
        </ul>

      )

    ) : (
      <p class="text-white/40 text-center py-12">
        Novos eventos em breve.{' '}
        <a href="/aplicacao/" class="text-mb-yellow underline">Seja membro</a>
        {' '}para receber em primeira mão.
      </p>
    )}

    <!-- CTA candidatura -->
    <div class="mt-10 text-center" data-animate>
      <p class="text-white/50 text-sm mb-4">
        Membros recebem acesso antecipado, reservas prioritárias e contexto antes da sala abrir.
      </p>
      <a href="/aplicacao/" class="btn-primary">
        Quero participar
      </a>
    </div>

  </div>
</section>
